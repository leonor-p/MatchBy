<!DOCTYPE html>
<html lang="en" class="thin-scroll">

<head>
    <title>MatchBy</title>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>

    <script>
        (function () {
            const KEY = 'color-theme';
            const root = document.documentElement;

            function desiredTheme() {
                const saved = localStorage.getItem(KEY);
                const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
                return saved ?? (prefersDark ? 'dark' : 'light');
            }

            function apply(theme) {
                // keep .dark if needed
                root.classList.toggle('dark', theme === 'dark');
            }

            // 1) apply immediately
            apply(desiredTheme());

            // 2) protect against clobbering of class attribute
            const origSetAttribute = root.setAttribute.bind(root);
            root.setAttribute = function (name, value) {
                if (name === 'class') {
                    const t = desiredTheme();
                    if (t === 'dark' && value && !/\bdark\b/.test(value)) {
                        value = (value + ' dark').trim();
                    }
                }
                return origSetAttribute(name, value);
            };

            // 3) heal if someone still removes it later
            let healing = false;
            const mo = new MutationObserver((muts) => {
                if (healing) return;
                if (!root.classList.contains('dark') && desiredTheme() === 'dark') {
                    healing = true;
                    root.classList.add('dark');
                    healing = false;
                }
            });
            mo.observe(root, {attributes: true, attributeFilter: ['class']});

            // optional: keep in sync with system when no saved preference
            const saved = localStorage.getItem(KEY);
            if (!saved && window.matchMedia) {
                const mq = matchMedia('(prefers-color-scheme: dark)');
                mq.addEventListener('change', () => apply(desiredTheme()));
            }
        })();
    </script>
    <link rel="stylesheet" href="@Assets["css/app.css"]"/>
    <link rel="stylesheet" href="@Assets["css/MatchBy.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet/>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;600;700;800&amp;display=swap"
          rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300..800&family=Momo+Trust+Display&display=swap"
