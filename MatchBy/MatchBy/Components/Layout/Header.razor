@using Microsoft.AspNetCore.Authorization
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider Auth
@using System.Security.Claims
@attribute [Authorize]

<header>
    <nav
        class="bg-[var(--section)] border-b-3 border-[var(--main)] px-4 py-2.5">
        <div class="flex flex-wrap justify-between items-center mx-auto max-w-screen-xl">
            <div class="flex justify-start items-center">
                <button
                    data-collapse-toggle="mobile-menu-2"
                    aria-controls="drawer-navigation"
                    class="p-2 mr-2 rounded-lg cursor-pointer md:hidden text-[var(--text)] hover:text-[var(--main)] focus:text-[var(--main)]"
                >
                    <svg
                        aria-hidden="true"
                        class="w-6 h-6"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h6a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
                            clip-rule="evenodd"
                        ></path>
                    </svg>
                    <svg
                        aria-hidden="true"
                        class="hidden w-6 h-6"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                            clip-rule="evenodd"
                        ></path>
                    </svg>
                    <span class="sr-only">Toggle sidebar</span>
                </button>
                <a href="" class="flex items-center justify-between mr-4">
                    <img
                        src="https://flowbite.s3.amazonaws.com/logo.svg"
                        class="mr-3 h-8"
                        alt="Flowbite Logo"
                    />
                    <span class="self-center text-2xl font-semibold whitespace-nowrap dark:text-white">MatchBy</span>
                </a>
            </div>
            <div class="flex items-center lg:order-2">
                <DarkModeToggle></DarkModeToggle>
                <AuthorizeView>
                    <Authorized>
                        <NotificationsHeader UserId="@_userId"></NotificationsHeader>
                        <button
                            type="button"
                            class="flex mx-3 text-sm rounded-full md:mr-0 focus:ring-2 focus:ring-[var(--main)]"
                            id="user-menu-button"
                            aria-expanded="false"
                            data-dropdown-toggle="dropdown">
                            <span class="sr-only">Open user menu</span>
                            <img
                                class="w-8 h-8 rounded-full object-cover"
                                src="/api/profile-image"
                                alt="user photo"/>
                        </button>
                        <!-- Dropdown menu -->
                        <div
                            class="hidden z-50 my-4 w-56 text-base list-none bg-[var(--section-secondary)] divide-y divide-[var(--main)] shadow rounded-xl"
                            id="dropdown">
                            <div class="py-3 px-4">
                                <span
                                    class="block text-sm font-semibold text-[var(--text)] truncate">@context.User.FindFirst(ClaimTypes.Name)?.Value</span>
                                <span
                                    class="block text-sm text-[var(--main)] truncate">@context.User.FindFirst(ClaimTypes.Email)?.Value</span>
                            </div>
                            <ul
                                class="py-1 text-gray-700 dark:text-gray-300"
                                aria-labelledby="dropdown">
                                <li>
                                    <NavLink
                                        href="/profile"
                                        class="flex items-center py-2 px-4 text-sm text-[var(--text)] group">
                                        <svg class="mr-2 w-5 h-5 text-[var(--text)] group-hover:text-[var(--main)]"
                                             aria-hidden="true"
                                             xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                             fill="currentColor"
                                             viewBox="0 0 24 24">
                                            <path fill-rule="evenodd"
                                                  d="M4 4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H4Zm10 5a1 1 0 0 1 1-1h3a1 1 0 1 1 0 2h-3a1 1 0 0 1-1-1Zm0 3a1 1 0 0 1 1-1h3a1 1 0 1 1 0 2h-3a1 1 0 0 1-1-1Zm0 3a1 1 0 0 1 1-1h3a1 1 0 1 1 0 2h-3a1 1 0 0 1-1-1Zm-8-5a3 3 0 1 1 6 0 3 3 0 0 1-6 0Zm1.942 4a3 3 0 0 0-2.847 2.051l-.044.133-.004.012c-.042.126-.055.167-.042.195.006.013.02.023.038.039.032.025.08.064.146.155A1 1 0 0 0 6 17h6a1 1 0 0 0 .811-.415.713.713 0 0 1 .146-.155c.019-.016.031-.026.038-.04.014-.027 0-.068-.042-.194l-.004-.012-.044-.133A3 3 0 0 0 10.059 14H7.942Z"
                                                  clip-rule="evenodd"/>
                                        </svg>

                                        <span
                                            class="text-[var(--text)] group-hover:text-[var(--main)]">My Profile</span>
                                    </NavLink>
                                </li>
                                <li>
                                    <NavLink
                                        href="/chat"
                                        class="flex items-center py-2 px-4 text-sm text-[var(--text)] group">
                                        <svg class="mr-2 w-5 h-5 text-[var(--text)] group-hover:text-[var(--main)]"
                                             aria-hidden="true"
                                             xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                             fill="currentColor"
                                             viewBox="0 0 640 640">
                                            <path fill-rule="evenodd" clip-rule="evenodd"
                                                  d="M416 208C416 305.2 330 384 224 384C197.3 384 171.9 379 148.8 370L67.2 413.2C57.9 418.1 46.5 416.4 39 409C31.5 401.6 29.8 390.1 34.8 380.8L70.4 313.6C46.3 284.2 32 247.6 32 208C32 110.8 118 32 224 32C330 32 416 110.8 416 208zM416 576C321.9 576 243.6 513.9 227.2 432C347.2 430.5 451.5 345.1 463 229.3C546.3 248.5 608 317.6 608 400C608 439.6 593.7 476.2 569.6 505.6L605.2 572.8C610.1 582.1 608.4 593.5 601 601C593.6 608.5 582.1 610.2 572.8 605.2L491.2 562C468.1 571 442.7 576 416 576z"/>
                                        </svg>

                                        <span class="text-[var(--text)] group-hover:text-[var(--main)]">Chat</span>
                                    </NavLink>
                                </li>
                                <li>
                                    <NavLink
                                        href="/Account/Manage"
                                        onclick="setTimeout(location.reload.bind(location), 1)"
                                        class="flex items-center py-2 px-4 text-sm group">
                                        <svg class="mr-2 w-5 h-5 text-[var(--text)] group-hover:text-[var(--main)]"
                                             aria-hidden="true"
                                             xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                             fill="currentColor"
                                             viewBox="0 0 24 24">
                                            <path fill-rule="evenodd"
                                                  d="M17 10v1.126c.367.095.714.24 1.032.428l.796-.797 1.415 1.415-.797.796c.188.318.333.665.428 1.032H21v2h-1.126c-.095.367-.24.714-.428 1.032l.797.796-1.415 1.415-.796-.797a3.979 3.979 0 0 1-1.032.428V20h-2v-1.126a3.977 3.977 0 0 1-1.032-.428l-.796.797-1.415-1.415.797-.796A3.975 3.975 0 0 1 12.126 16H11v-2h1.126c.095-.367.24-.714.428-1.032l-.797-.796 1.415-1.415.796.797A3.977 3.977 0 0 1 15 11.126V10h2Zm.406 3.578.016.016c.354.358.574.85.578 1.392v.028a2 2 0 0 1-3.409 1.406l-.01-.012a2 2 0 0 1 2.826-2.83ZM5 8a4 4 0 1 1 7.938.703 7.029 7.029 0 0 0-3.235 3.235A4 4 0 0 1 5 8Zm4.29 5H7a4 4 0 0 0-4 4v1a2 2 0 0 0 2 2h6.101A6.979 6.979 0 0 1 9 15c0-.695.101-1.366.29-2Z"
                                                  clip-rule="evenodd"/>
                                        </svg>
                                        <span
                                            class="text-[var(--text)] group-hover:text-[var(--main)]">Account Settings</span>
                                    </NavLink>
                                </li>

                            </ul>
                            <ul aria-labelledby="dropdown">
                                <li class="group">
                                    <form action="Account/Logout" method="post">
                                        <AntiforgeryToken/>
                                        <input type="hidden" name="ReturnUrl" value="@_currentUrl"/>
                                        <button type="submit"
                                                class="flex items-center py-2 px-4 text-sm text-[var(--text)]">
                                            <svg class="mr-2 w-5 h-5 text-[var(--text)] group-hover:text-[var(--main)]"
                                                 aria-hidden="true"
                                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                                 viewBox="0 0 24 24">
                                                <path stroke="currentColor" stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      stroke-width="2"
                                                      d="M20 12H8m12 0-4 4m4-4-4-4M9 4H7a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h2"/>
                                            </svg>
                                            <span
                                                class="text-[var(--text)] group-hover:text-[var(--main)]">Logout</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="lg:flex items-center lg:order-2 hidden">
                            <NavLink href="/Account/Login"
                                     class="text-[var(--text)] hover:text-[var(--main)] font-medium rounded-lg text-sm px-4 lg:px-5 py-2 lg:py-2.5 mr-2">
                                Log
                                in
                            </NavLink>
                            <NavLink href="/Account/Register"
                                     class="text-[var(--text-contrast)] bg-[var(--main)] hover:bg-[var(--main-hover)] font-medium rounded-lg text-sm px-4 lg:px-5 py-2 lg:py-2.5 mr-2 focus:outline-none">
                                Register
                            </NavLink>
                        </div>
                        <div class="flex lg:hidden items-center">
                            <NavLink href="/Account/Login" class="p-2 text-[var(--text)]">
                                <svg class="w-6 h-6 text-[var(--text)]" aria-hidden="true"
                                     xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 16">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M4 8h11m0 0-4-4m4 4-4 4m-5 3H3a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h3"/>
                                </svg>

                            </NavLink>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <div class="hidden justify-between items-center w-full lg:flex lg:w-auto lg:order-1" id="mobile-menu-2">
                <ul class="flex flex-col mt-4 font-medium lg:flex-row lg:space-x-8 lg:mt-0">
                    <li>
                        <NavLink href="/" Match="NavLinkMatch.All" ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0"
                                 aria-current="page">Home
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/matches" Match="NavLinkMatch.Prefix" ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0">
                            Matches
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/users" Match="NavLinkMatch.Prefix"
                                 ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0">
                            Users
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/teams" Match="NavLinkMatch.Prefix"
                                 ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0">
                            Teams
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/about" Match="NavLinkMatch.Prefix"
                                 ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0">
                            About
                        </NavLink>
                    </li>
                    <li>
                        <NavLink href="/contact" Match="NavLinkMatch.Prefix"
                                 ActiveClass="!text-[var(--main)]"
                                 class="block py-2 pr-4 pl-3 text-[var(--text)] border-b border-[var(--section-secondary)] lg:hover:bg-transparent lg:border-0 lg:hover:text-[var(--main)] lg:p-0">
                            Contact
                        </NavLink>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

@code {
    private string? _currentUrl;
    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        var authState = await Auth.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }
    
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }


    public ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        return ValueTask.CompletedTask;
    }

}
