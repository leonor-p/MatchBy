@inherits LayoutComponentBase
@layout Layout.MainLayout

<section class="max-w-7xl mx-auto px-4 lg:px-8 py-6 ">
    <header class="mb-6">
        <h1 class="text-3xl font-semibold text-[var(--text)]">Account settings</h1>
        <div class="h-px bg-[var(--main)] mt-4"></div>
    </header>
    
    <details class="lg:hidden mb-4 rounded-lg border border-[var(--main)]">
        <summary class="cursor-pointer px-4 py-3 text-sm font-medium text-[var(--text)]  select-none">
            Menu
        </summary>
        <div class="px-4 py-3">
            <ManageNavMenu />
        </div>
    </details>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <aside class="hidden lg:block lg:col-span-3">
            <div class="sticky top-4">
                <ManageNavMenu />
            </div>
        </aside>
        
        <main class="lg:col-span-6">
            <div class="rounded-xl bg-[var(--section)] ring-1 ring-[var(--main)] shadow-sm p-6 lg:p-8">
                <div class="max-w-2xl">
                    @Body
                </div>
            </div>
        </main>

        <div class="hidden lg:block lg:col-span-3"></div>
    </div>
</section>

