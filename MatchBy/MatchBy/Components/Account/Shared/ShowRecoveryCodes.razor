<StatusMessage Message="@StatusMessage" />

<section class="space-y-6">
    <h2 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Recovery codes</h2>

    <div class="p-4 rounded-lg bg-yellow-50 dark:bg-gray-800 border border-yellow-200 dark:border-gray-700 text-yellow-800 dark:text-yellow-300">
        <p class="font-medium mb-2">
            <strong>Store these recovery codes in a safe place.</strong>
        </p>
        <p class="text-sm leading-relaxed">
            If you lose your device and don’t have these recovery codes, you will lose access to your account.
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        @foreach (var recoveryCode in RecoveryCodes)
        {
            <div class="px-4 py-2 text-center font-mono text-sm tracking-wider rounded-lg border border-gray-300 bg-gray-50
                        dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100">
                <code>@recoveryCode</code>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string[] RecoveryCodes { get; set; } = [];

    [Parameter] public string? StatusMessage { get; set; }
}
