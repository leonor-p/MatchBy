@page "/Account/ResetPasswordConfirmation"

<PageTitle>Reset password confirmation</PageTitle>

<section class="flex flex-col items-center justify-center min-h-[70vh] text-center space-y-6">
    <div class="flex flex-col items-center space-y-4">
        <!-- Success icon -->
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-600 dark:text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M5 13l4 4L19 7" />
            </svg>
        </div>

        <h1 class="text-3xl font-semibold text-green-700 dark:text-green-400">
            Password reset successful
        </h1>
        <p class="text-gray-700 dark:text-gray-300 max-w-md" role="alert">
            Your password has been successfully reset. You can now log in using your new password.
        </p>
    </div>

    <div class="pt-4 flex space-x-4">
        <a href="/Account/Login"
           class="inline-flex justify-center px-6 py-2.5 rounded-lg text-sm font-medium text-white
                  bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-4 focus:ring-primary-300
                  dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
            Log in
        </a>

        <a href="/"
           class="inline-flex justify-center px-6 py-2.5 rounded-lg text-sm font-medium text-primary-700
                  bg-transparent border border-primary-600 hover:bg-primary-50 focus:outline-none focus:ring-4 focus:ring-primary-200
                  dark:text-primary-300 dark:border-primary-500 dark:hover:bg-primary-900 dark:focus:ring-primary-800">
            Return to home
        </a>
    </div>
</section>
