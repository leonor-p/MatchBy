@page "/Account/Register"
@using System.ComponentModel.DataAnnotations
@using MatchBy.Extensions
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Register> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Register</PageTitle>

<section class="bg-[var(--background)] min-h-screen flex items-center">
    <div class="grow flex flex-col lg:flex-row items-center justify-center px-6 py-8 mx-auto lg:py-0 lg:px-0">
        <!-- Left Column: Register Form -->
        <div class="w-full lg:w-1/2 flex items-center justify-center lg:justify-end lg:px-8 xl:px-16">
            <div class="w-full max-w-md">
                <div class="bg-[var(--section)] rounded-lg shadow-lg p-8 ring-1 ring-[var(--main)]">
                    <h1 class="text-2xl font-bold leading-tight tracking-tight text-[var(--text)] mb-2">
                        Create an account
                    </h1>
                    <p class="text-sm text-[var(--text)] mb-6">
                        Already have an account?
                        <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))"
                           class="font-medium text-[var(--main)] hover:underline">Login here</a>.
                    </p>

                    <StatusMessage Message="@Message" UseCookieMessage="false"/>
                    @if (InputRegister is not null)
                    {
                        <EditForm Model="InputRegister" method="post" OnValidSubmit="RegisterUser" FormName="register"
                                  class="space-y-3">
                            <DataAnnotationsValidator/>

                            <!-- Email -->
                            <div>
                                <label for="InputRegister.Email"
                                       class="block mb-2 text-sm font-medium text-[var(--text)]">Email</label>
                                <InputText @bind-Value="InputRegister.Email"
                                           id="InputRegister.Email"
                                           type="email"
                                           class="block w-full p-2.5 rounded-lg
                                        bg-[var(--section-secondary)]
                                        text-[var(--text)]
                                        focus:border-[var(--main)]
                                        focus:ring-1 focus:ring-[var(--main)]
                                        focus:outline-none
                                        border-0"
                                           placeholder="john@email.com"
                                           autocomplete="email"/>
                                <ValidationMessage For="() => InputRegister.Email" class="text-danger"/>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <!-- Username -->
                                <div>
                                    <label for="InputRegister.Username"
                                           class="block mb-2 text-sm font-medium text-[var(--text)]">Username</label>
                                    <InputText @bind-Value="InputRegister.Username"
                                               id="InputRegister.Username"
                                               class="block w-full p-2.5 rounded-lg
                                        bg-[var(--section-secondary)]
                                        text-[var(--text)]
                                        focus:border-[var(--main)]
                                        focus:ring-1 focus:ring-[var(--main)]
                                        focus:outline-none
                                        border-0"
                                               placeholder="john"/>
                                    <ValidationMessage For="() => InputRegister.Username" class="text-danger"/>
                                </div>

                                <!-- Display Name -->
                                <div>
                                    <label for="InputRegister.DisplayName"
                                           class="block mb-2 text-sm font-medium text-[var(--text)]">Display
                                        Name</label>
                                    <InputText @bind-Value="InputRegister.DisplayName"
                                               id="InputRegister.DisplayName"
                                               class="block w-full p-2.5 rounded-lg
                                        bg-[var(--section-secondary)]
                                        text-[var(--text)]
                                        focus:border-[var(--main)]
                                        focus:ring-1 focus:ring-[var(--main)]
                                        focus:outline-none
                                        border-0"
                                               placeholder="john doe"/>
                                    <ValidationMessage For="() => InputRegister.DisplayName" class="text-danger"/>
                                </div>

                                <!-- Password -->
                                <div>
                                    <label for="InputRegister.Password"
                                           class="block mb-2 text-sm font-medium text-[var(--text)]">Password</label>
                                    <InputText @bind-Value="InputRegister.Password"
                                               id="InputRegister.Password"
                                               type="password"
                                               class="block w-full p-2.5 rounded-lg
                                        bg-[var(--section-secondary)]
                                        text-[var(--text)]
                                        focus:border-[var(--main)]
                                        focus:ring-1 focus:ring-[var(--main)]
                                        focus:outline-none
                                        border-0"
                                               placeholder="••••••••"
                                               autocomplete="new-password"/>
                                    <ValidationMessage For="() => InputRegister.Password" class="text-danger"/>
                                </div>

                                <!-- Confirm Password -->
                                <div>
                                    <label for="InputRegister.ConfirmPassword"
                                           class="block mb-2 text-sm font-medium text-[var(--text)]">Confirm
                                        Password</label>
                                    <InputText @bind-Value="InputRegister.ConfirmPassword"
                                               id="InputRegister.ConfirmPassword"
                                               type="password"
                                               class="block w-full p-2.5 rounded-lg
                                        bg-[var(--section-secondary)]
                                        text-[var(--text)]
                                        focus:border-[var(--main)]
                                        focus:ring-1 focus:ring-[var(--main)]
                                        focus:outline-none
                                        border-0"
                                               placeholder="••••••••"
                                               autocomplete="new-password"/>
                                    <ValidationMessage For="() => InputRegister.ConfirmPassword" class="text-danger"/>
                                </div>
                            </div>

                            <!-- Accept Terms -->
                            <div class="mt-4">
                                <div class="w-full flex flex-row h-5">
                                    <InputCheckbox @bind-Value="InputRegister.AcceptTerms"
                                                   id="InputRegister.AcceptTerms"
                                                   class="w-4 h-4 text-[var(--main-hover)] bg-gray-100 hover:text-[var(--main-hover)] border-gray-300 rounded-sm focus:ring-0"/>
                                    <div class="ml-3 text-sm">
                                        <label for="InputRegister.AcceptTerms" 
                                               class="text-[var(--text)]"
                                               target="_blank" 
                                               rel="noopener noreferrer">
                                            I accept the
                                            <NavLink href="/TermsAndConditions"
                                               class="font-medium text-[var(--main)] hover:underline">Terms and
                                                Conditions</NavLink>
                                        </label>
                                    </div>
                                </div>
                                <ValidationMessage For="() => InputRegister.AcceptTerms" class="text-danger block"/>
                            </div>

                            <!-- Submit -->
                            <div>
                                <button type="submit"
                                        class="mt-2 w-full text-[var(--text-contrast)] bg-[var(--main)] hover:bg-[var(--main-hover)] font-medium rounded-lg text-sm px-5 py-2.5 text-center">
                                    Create account
                                </button>
                            </div>
                        </EditForm>
                    }

                    <div class="mt-6">
                        <div class="relative">
                            <div class="absolute inset-0 flex items-center">
                                <div class="w-full border-t border-gray-300"></div>
                            </div>
                            <div class="relative flex justify-center text-sm">
                                <span class="px-2 bg-[var(--section)] text-[var(--text)]">or</span>
                            </div>
                        </div>
                        <div class="mt-6">
                            <ExternalLoginPicker/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Illustration -->
        <div class="hidden lg:flex lg:w-1/2 items-center justify-center lg:justify-start p-8">
            <div class="w-full max-w-lg">
                <img src="/images/register/registerImage.png"
                     alt="Registration illustration"
                     class="w-full h-auto"/>
            </div>
        </div>
    </div>
</section>


@code {
    private IEnumerable<IdentityError>? _identityErrors;
    private string? Message => _identityErrors is null ? null : $"Error: {string.Join(", ", _identityErrors.Select(error => error.Description))}";

    [SupplyParameterFromForm] private InputModel? InputRegister { get; set; }
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    protected override void OnInitialized() => InputRegister ??= new InputModel();
    
    private async Task RegisterUser()
    {
        if (InputRegister is null)
        {
            return;
        }

        var user = CreateUser().InitializeNewUser(InputRegister.DisplayName);

        await UserStore.SetUserNameAsync(user, InputRegister.Username, CancellationToken.None);

        var emailStore = GetEmailStore();
        await emailStore.SetEmailAsync(user, InputRegister.Email, CancellationToken.None);

        if (await UserManager.FindByEmailAsync(InputRegister.Email) is not null)
        {
            _identityErrors = [new IdentityError { Code = "DuplicateEmail", Description = "Email address is already in use." }];
            return;
        }

        var result = await UserManager.CreateAsync(user, InputRegister.Password);
        if (!result.Succeeded)
        {
            _identityErrors = result.Errors;
            return;
        }

        Logger.LogInformation("User created a new account with password.");

        await UserManager.AddToRoleAsync(user, Roles.Member);

        if (UserManager.Options.SignIn.RequireConfirmedAccount)
        {
            RedirectManager.RedirectTo(
                "Account/RegisterConfirmation",
                new Dictionary<string, object?> { ["email"] = InputRegister.Email, ["returnUrl"] = ReturnUrl });
        }

        await SignInManager.SignInAsync(user, isPersistent: false);
        RedirectManager.RedirectTo(ReturnUrl);
    }

    private static ApplicationUser CreateUser()
    {
        try
        {
            return Activator.CreateInstance<ApplicationUser>();
        }
        catch
        {
            throw new InvalidOperationException($"Can't create an instance of '{nameof(ApplicationUser)}'. " +
                                                $"Ensure that '{nameof(ApplicationUser)}' is not an abstract class and has a parameterless constructor.");
        }
    }

    private IUserEmailStore<ApplicationUser> GetEmailStore()
    {
        if (!UserManager.SupportsUserEmail)
        {
            throw new NotSupportedException("The default UI requires a user store with email support.");
        }

        return (IUserEmailStore<ApplicationUser>)UserStore;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "Password")]
        public string Password { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        [Display(Name = "Confirm password")]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        [MaxLength(50, ErrorMessage = "Username cannot exceed 50 characters.")]
        public string Username { get; set; } = "";

        [Required]
        [MaxLength(50, ErrorMessage = "Display Name cannot exceed 50 characters.")]
        public string DisplayName { get; set; } = "";

        [Range(typeof(bool), "true", "true", ErrorMessage = "You must accept the terms and conditions.")]
        public bool AcceptTerms { get; set; }
    }

}