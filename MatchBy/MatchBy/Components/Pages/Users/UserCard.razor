@using MatchBy.DTOs.User
<div @onclick="OnCardClick"
     class="bg-[var(--section-secondary)] rounded-lg border-2 border-[var(--main)] p-4 cursor-pointer hover:shadow-lg transition-shadow duration-200 hover:border-[var(--main-hover)]">

    <div class="flex flex-col items-center mb-3">
        <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-[var(--main)] mb-2">
            @if (User.AvatarUrl != null)
            {
                <img src="@User.AvatarUrl" alt="@User.DisplayName"
                     class="w-full h-full object-cover"/>
            }
            else
            {
                <img src="images/user-avatar.png" alt="@User.DisplayName"
                     class="w-full h-full object-cover"/>
            }
        </div>

        <h3 class="font-semibold text-lg text-[var(--text)] text-center">
            @User.DisplayName
        </h3>
        <p class="text-[var(--text)] text-sm opacity-75">&#64;@User.UserName</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(User.Bio))
    {
        <p class="text-[var(--text)] text-sm mb-3 line-clamp-2 text-center">
            @User.Bio
        </p>
    }

    @if (User.PreferredSports.Any())
    {
        <div class="flex items-center justify-center gap-2 mb-3 flex-wrap">
            @foreach (var sport in User.PreferredSports.Take(4))
            {
                <div class="bg-[var(--section)] px-3 py-1 rounded border border-[var(--main)]">
                    <span class="text-xs text-[var(--text)] font-medium">
                        @sport.ToString()
                    </span>
                </div>
            }

            @if (User.PreferredSports.Count > 4)
            {
                <span class="text-[var(--text)] text-sm">
                    +@(User.PreferredSports.Count - 4)
                </span>
            }
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center gap-2 mb-3 text-center">
            <div class="text-sm text-[var(--text)]">
                No sports selected yet.
            </div>
        </div>
    }


    <div class="flex items-center justify-between pt-3 border-t border-[var(--main)]">
        @if (User.PlayerRating >= 0)
        {
            <div class="flex items-center text-yellow-400">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="font-semibold text-[var(--text)]">@User.PlayerRating.ToString("F1")</span>
            </div>
        }

        @if (User.JoinedMatchesCount >= 0)
        {
            <div class="text-[var(--text)] text-sm">
                <span class="font-semibold">@User.JoinedMatchesCount</span> matches
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public required UserDto User { get; set; }
    [Parameter] public required EventCallback<string> OnClick { get; set; }

    private void OnCardClick() => OnClick.InvokeAsync(User.Id);
}
