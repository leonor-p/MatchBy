@page "/chat"
@page "/chat/{conversationId}"

@using FluentValidation
@using MatchBy.DTOs.Chat.Conversations
@using MatchBy.DTOs.Chat.Messages
@using MatchBy.Services.ChatMessages
@using MatchBy.Services.Conversations
@using MatchBy.Services.Users
@using Microsoft.AspNetCore.Authorization
@using Blazorise
@using System.ComponentModel
@using MatchBy.DTOs.User
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider Auth
@inject IConversationService ConversationService
@inject IChatMessageService ChatMessageService
@inject IUsersService UsersService
@inject ChatState State
@inject NavigationManager NavigationManager
@inject IValidator<CreateChatMessageDto> CreateChatMessageDtoValidator
@inject IValidator<UpdateChatMessageDto> UpdateChatMessageDtoValidator
@inject IValidator<CreateConversationDto> CreateConversationDtoValidator
@inject IValidator<UpdateConversationDto> UpdateConversationDtoValidator
@inject IToastService ToastService

<div class="flex flex-1 min-h-0 overflow-hidden min-h-[calc(100vh-107px-32px)]">
    <!-- Sidebar Desktop -->
    <div class="hidden md:flex md:flex-col w-64 lg:w-72 xl:w-80 border-r border-[var(--main)] overflow-hidden">
        <ChatSidebar
            Class="flex flex-col h-full overflow-hidden max-h-[calc(100vh-107px-32px)]"
            Conversations="@(_viewModel?.State.Conversations ?? [])"
            OnConversationSelected="OnConversationSelected"
            OnShowModal="ShowModal"
            OnNext="LoadMoreConversations"
            NextCursor="@(_viewModel?.State.NextConversationCursor)"
            CurrentUserId="@(_viewModel?.State.UserId ?? string.Empty)"
            OnSearch="SearchConversations"/>
    </div>
    <!-- Main Chat Area -->
    <main class="flex-1 flex flex-col max-h-[calc(100vh-107px-32px)] min-w-0 overflow-hidden">
        @if (_viewModel?.State.Selected is null)
        {
            <ChatEmptyState/>
        }
        else
        {
            <ChatHeader
                Conversation="@(_viewModel.State.Selected)"
                OnOpenInfo="ShowOffcanvas"
                CurrentUserId="@(_viewModel.State.UserId)"/>

            <!-- Messages Container with isolated scroll -->
            <div class="flex flex-col flex-1 min-h-0 overflow-hidden">
                <MessageList
                    ChatMessages="@(_viewModel.State.MessagesOfSelectedConversation)"
                    CurrentUserId="@(_viewModel.State.UserId)"
                    OnEdit="OnEditMessage"
                    OnReply="OnReplyToMessage"
                    OnDelete="OnDeleteMessage"
                    OnNext="LoadMoreMessages"
                    NextCursor="@(_viewModel.State.NextChatMessagesCursor)"/>
            </div>

            <ChatFooter
                Text="@(_viewModel.MessageText)"
                TextChanged="v => _viewModel.MessageText = v"
                ReplyTo="@(_viewModel.ReplyToMessage)"
                OnCancelReply="CancelReply"
                OnSend="HandleSubmit"
                OnShareLocation="ShareLocation"/>
        }
    </main>
</div>

<!-- Mobile Sidebar Button -->
<Button Clicked="@ShowSidebarOffcanvas"
        Class="md:hidden fixed bottom-36 left-4 z-50 rounded-full !p-3 bg-[var(--main)] text-[var(--text-contrast)] shadow-lg hover:scale-105 transition-transform">
    <Icon Name="IconName.List" Size="IconSize.Small"/>
</Button>

<!-- Offcanvas mobile (< md) -->
<Offcanvas @ref="_sidebarOffcanvas"
           Placement="Placement.Start"
           ShowBackdrop
           Style="border-right: 1px solid var(--main); background-color: var(--background); width: min(85vw, 320px);">
    <OffcanvasBody Class="!p-0 flex flex-col h-full max-h-full overflow-hidden">
        <ChatSidebar Class="w-full h-full max-h-full flex flex-col overflow-hidden"
                     Conversations="@(_viewModel?.State.Conversations ?? [])"
                     OnConversationSelected="OnConversationSelectedMobile"
                     OnShowModal="ShowModal"
                     OnNext="LoadMoreConversations"
                     NextCursor="@(_viewModel?.State.NextConversationCursor)"
                     CurrentUserId="@(_viewModel?.State.UserId ?? string.Empty)"
                     OnSearch="SearchConversations"/>
    </OffcanvasBody>
</Offcanvas>

@if (_viewModel?.State.Selected is not null)
{
    <ConversationInfoOffcanvas @ref="_offcanvas"
                               SelectedConversation="@(_viewModel.State.Selected)"
                               OnLeaveConversation="LeaveConversation"
                               OnDeleteConversation="DeleteConversation"
                               OnImageSubmit="OnUpdateConversation"
                               CurrentUserId="@(_viewModel.State.UserId)"/>
}

<NewConversationModal @ref="_modal"
                      OnCreate="StartChat"
                      OnGetUsers="GetUsers"
                      Users="@(_viewModel?.AllUsers ?? new PaginationResponse<List<UserDto>>
                             {
                                 Page = 0,
                                 TotalCount = 0,
                                 PageSize = 0,
                                 Data = []
                             })"/>

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>


@code{
    [Parameter] public string? ConversationId { get; set; }
    
    private ChatViewModel? _viewModel;
    private PropertyChangedEventHandler? _propertyChangedHandler;
    private EventHandler? _stateChangedHandler;
    
    private async Task ShowSidebarOffcanvas() => await _sidebarOffcanvas.Show();
    private async Task HideSidebarOffcanvas() => await _sidebarOffcanvas.Hide();

    private async Task OnConversationSelectedMobile(ConversationDto conversation)
    {
        if (_viewModel is null) return;
        await _viewModel.OnConversationSelected(conversation);
        await HideSidebarOffcanvas();
    }

    private Offcanvas _sidebarOffcanvas = default!;
    private ConversationInfoOffcanvas _offcanvas = default!;
    private NewConversationModal _modal = default!;

    protected override void OnInitialized()
    {
        _viewModel = new ChatViewModel(
            ConversationService,
            ChatMessageService,
            UsersService,
            State,
            NavigationManager,
            CreateChatMessageDtoValidator,
            UpdateChatMessageDtoValidator,
            CreateConversationDtoValidator,
            UpdateConversationDtoValidator,
            ToastService,
            async () => await InvokeAsync(StateHasChanged));
        
        _propertyChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        _stateChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        
        _viewModel.PropertyChanged += _propertyChangedHandler;
        _viewModel.StateChanged += _stateChangedHandler;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_viewModel is null) return;
        
        var user = (await Auth.GetAuthenticationStateAsync()).User;
        var userId = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
        if (userId is null) return;

        await _viewModel.InitializeAsync(ConversationId, userId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _viewModel is null) return;
        await _viewModel.InitializeSignalRAsync();
    }

    public async Task SearchConversations(string? search)
    {
        if (_viewModel is null) return;
        await _viewModel.SearchConversations(search);
    }

    public async Task LoadMoreConversations((string? nextCursor, string? search) args)
    {
        if (_viewModel is null) return;
        await _viewModel.LoadMoreConversations(args);
    }

    public async Task LoadMoreMessages(string? nextCursor)
    {
        if (_viewModel is null) return;
        await _viewModel.LoadMoreMessages(nextCursor);
    }

    private async Task GetUsers(NewConversationModal.UsersQuery usersQuery)
    {
        if (_viewModel is null) return;
        await _viewModel.GetUsers(usersQuery);
    }

    private Task ShowOffcanvas() => _offcanvas.Show();
    private Task ShowModal() => _modal.Show();

    private async Task HandleSubmit()
    {
        if (_viewModel is null) return;
        await _viewModel.HandleSubmit();
    }

    private async Task ShareLocation((double Latitude, double Longitude) location)
    {
        if (_viewModel is null) return;
        await _viewModel.ShareLocation(location);
    }

    private async Task OnEditMessage(UpdateChatMessageDto msg)
    {
        if (_viewModel is null) return;
        await _viewModel.OnEditMessage(msg);
    }

    private async Task OnDeleteMessage(ChatMessageDto msg)
    {
        if (_viewModel is null) return;
        await _viewModel.OnDeleteMessage(msg);
    }

    private Task OnReplyToMessage(ChatMessageDto msg) => _viewModel is null ? Task.CompletedTask : _viewModel.OnReplyToMessage(msg);

    private Task CancelReply()
    {
        if (_viewModel is null) return Task.CompletedTask;
        return _viewModel.CancelReply();
    }

    private async Task StartChat(string otherUserId)
    {
        if (_viewModel is null) return;
        await _viewModel.StartChat(otherUserId);
    }

    private async Task LeaveConversation()
    {
        if (_viewModel is null) return;
        await _viewModel.LeaveConversation();
    }

    private async Task DeleteConversation()
    {
        if (_viewModel is null) return;
        await _viewModel.DeleteConversation();
    }

    public async Task OnConversationSelected(ConversationDto conversation)
    {
        if (_viewModel is null) return;
        await _viewModel.OnConversationSelected(conversation);
    }

    public async Task OnUpdateConversation(UpdateConversationDto updateConversationDto)
    {
        if (_viewModel is null) return;
        await _viewModel.OnUpdateConversation(updateConversationDto);
    }

    public async ValueTask DisposeAsync()
    {
        if (_viewModel is not null)
        {
            if (_propertyChangedHandler is not null)
            {
                _viewModel.PropertyChanged -= _propertyChangedHandler;
            }
            if (_stateChangedHandler is not null)
            {
                _viewModel.StateChanged -= _stateChangedHandler;
            }
            await _viewModel.DisposeAsync();
        }
    }
}