@using MatchBy.DTOs.Chat.Conversations

<button @onclick="() => OnConversationSelected.InvokeAsync(Conversation)"
        class="w-full flex items-start gap-3 px-2 py-2 rounded-lg hover:opacity-80 transition-opacity"
        style="color: var(--text);">
    <span class="relative">
        @if(Conversation.Type == ConversationType.Private)
        {
            var otherParticipant = Conversation.Participants.FirstOrDefault(p => p.Id != CurrentUserId);
            <img class="size-10 rounded-full"
                 src="@(otherParticipant?.ImageUrl ?? "/images/user-avatar.png")"
                 alt="">
        }
        else if(Conversation.Type == ConversationType.Team)
        {
            <img class="size-10 rounded-full"
                 src="@(Conversation.TeamImageUrl ?? "/images/user-avatar.png")"
                 alt="">
        }
        else 
        {
            <img class="size-10 rounded-full"
                 src="@(Conversation.ImageUrl ?? "/images/user-avatar.png")"
                 alt="">
        }
        <span class="absolute -bottom-0.5 -right-0.5 size-2.5 rounded-full ring-2"
              style="background-color: var(--error); border-color: var(--background);"></span>
    </span>

    <span class="min-w-0 flex-1 text-left">
        <span class="flex items-center justify-between">
            @if(Conversation.Type == ConversationType.Private)
            {
                var otherParticipant = Conversation.Participants.FirstOrDefault(p => p.Id != CurrentUserId);
                <span class="text-[15px] font-medium truncate" style="color: var(--text);">@otherParticipant?.DisplayName</span>
            }
            else
            {
                <span class="text-[15px] font-medium truncate" style="color: var(--text);">@Conversation.Title</span>
            }

            @if (Conversation.LastMessageAtUtc is not null)
            {
                <span class="text-[11px] opacity-60" style="color: var(--text);">@Conversation.LastMessageAtUtc.Value.ToString("HH:mm")</span>
            }
        </span>

        <span class="mt-0.5 text-xs truncate opacity-60"
              style="color: var(--text);">
            @(Conversation.LastMessageContent ?? "No messages yet")
        </span>
    </span>
</button>

@code {
    [Parameter] public EventCallback<ConversationDto> OnConversationSelected { get; set; }
    [Parameter] public required ConversationDto Conversation { get; set; }
    [Parameter] public required string CurrentUserId { get; set; }
}