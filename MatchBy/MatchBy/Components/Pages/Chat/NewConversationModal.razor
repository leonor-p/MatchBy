@using Blazorise
@using MatchBy.DTOs.User

<Modal @ref="ModalRef">
    <ModalContent Centered Class="rounded-3 shadow border border-[var(--main)]"
                  Style="background-color: var(--background);"
                  Size="ModalSize.Default">
        <ModalHeader Style="border-color: var(--main); color: var(--text);">
            <ModalTitle>New conversation</ModalTitle>
            <CloseButton/>
        </ModalHeader>

        <ModalBody Class="pt-2 flex flex-col" Style="max-height: 60vh;">
            <!-- Search -->
            <Field Class="mb-3 flex-shrink-0">
                <TextEdit @bind-Text="_search"
                          Placeholder="Search for contacts"
                          Role="TextRole.Search"
                          KeyDown="OnSearchKeyDown"
                          Class="form-control-lg"
                          Style="background-color: var(--section-secondary); color: var(--text); border-color: var(--main);"/>
            </Field>

            @if (!_isLoading)
            {
                <!-- Contact list with flexible height -->
                <div class="flex-grow overflow-auto mb-3 min-h-[200px]">
                    <ListGroup Mode="ListGroupMode.Selectable"
                               @bind-SelectedItem="_selectedItem"
                               Flush
                               Style="background-color: var(--background);">
                        @if (Users.Data.Count == 0)
                        {
                            <ListGroupItem class="py-3 text-center opacity-60"
                                           Style="color: var(--text);">
                                No results
                            </ListGroupItem>
                        }
                        else
                        {
                            foreach (var u in Users.Data)
                            {
                                <ListGroupItem Name="@u.Id"
                                               class="flex items-center gap-3 py-2 cursor-pointer transition-opacity hover:opacity-70 contact-item"
                                               Style="color: var(--text);">
                                    <Image Loading src="@u.AvatarUrl" Alt="@u.DisplayName"
                                           class="rounded-full w-10 h-10 object-cover flex-shrink-0"/>
                                    <span class="fw-500 truncate">@u.DisplayName</span>
                                </ListGroupItem>
                            }
                        }
                    </ListGroup>
                </div>

                <!-- Pagination fixed at bottom -->
                <div class="flex justify-center flex-shrink-0">
                    <OffsetPagination CurrentPage="@_currentPage"
                                      OnPageChanged="GoToPage"
                                      PageSize="@PageSize"
                                      TotalItems="@Users.TotalCount"/>
                </div>
            }
            else
            {
                <div class="flex justify-center items-center flex-grow min-h-[200px]"
                     role="status">
                    <Loading/>
                </div>
            }
        </ModalBody>

        <ModalFooter Class="justify-content-between flex-shrink-0"
                     Style="border-color: var(--main);">
            <Button Class="px-4 transition-colors"
                    Style="background-color: var(--main); color: var(--text-contrast);"
                    Disabled="@(_selectedItem is null)"
                    Clicked="@StartChat">
                New chat
            </Button>
            <Button Color="Color.Secondary"
                    Outline
                    Class="px-4"
                    Clicked="@Hide">
                Cancel
            </Button>
        </ModalFooter>
    </ModalContent>
</Modal>


@code {
    private Modal ModalRef { get; set; } = new();
    private string _search = "";
    private string? _selectedItem;
    private int _currentPage = 1;
    private bool _isLoading;

    [Parameter] public EventCallback<string?> OnSearch { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public required PaginationResponse<List<UserDto>> Users { get; set; }
    [Parameter] public EventCallback<string> OnCreate { get; set; }
    [Parameter] public EventCallback<UsersQuery> OnGetUsers { get; set; }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        if (_isLoading) return;
        _isLoading = true;
        try
        {
            await OnGetUsers.InvokeAsync(new UsersQuery(_search, _currentPage, PageSize));
            StateHasChanged();
        }
        finally
        {
            _isLoading = false;
        }
    }

    public async Task Show() => await ModalRef.Show();
    public async Task Hide() => await ModalRef.Hide();

    private async Task StartChat()
    {
        if (_selectedItem is not null)
        {
            await OnCreate.InvokeAsync(_selectedItem);
            await Hide();
        }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _currentPage = 1;
            if (_isLoading) return;
            _isLoading = true;
            try
            {
                await OnGetUsers.InvokeAsync(new UsersQuery(_search, _currentPage, PageSize));
                StateHasChanged();
            }
            finally
            {
                _isLoading = false;
            }
        }
    }

    public record UsersQuery(string q, int page, int pageSize);
}