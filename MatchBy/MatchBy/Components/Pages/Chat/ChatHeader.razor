@using MatchBy.DTOs.Chat.Conversations
@using Blazorise

<header class="flex-none border-b px-3 sm:px-4 py-2.5 sm:py-3"
        style="background-color: var(--background); border-color: var(--main);">
    <div class="flex items-center gap-2 sm:gap-3 min-w-0">
        @if (Conversation.Type == ConversationType.Private)
        {
            var otherParticipant = Conversation.Participants.FirstOrDefault(p => p.Id != CurrentUserId);
            <img class="size-8 sm:size-9 rounded-full flex-none object-cover"
                 src="@(otherParticipant?.ImageUrl ?? "/images/user-avatar.png")"
                 alt="@Conversation.Title image"/>
            <div class="min-w-0 flex-1">
                <div class="font-semibold truncate text-sm sm:text-base" style="color: var(--text);">@otherParticipant?.DisplayName</div>
            </div>
        }
        else if (Conversation.Type == ConversationType.Team)
        {
            <img class="size-8 sm:size-9 rounded-full flex-none object-cover"
                 src="@(Conversation.TeamImageUrl ?? "/images/user-avatar.png")"
                 alt="@Conversation.Title image"/>
            <div class="min-w-0 flex-1">
                <div class="font-semibold truncate text-sm sm:text-base" style="color: var(--text);">@Conversation.Title</div>
            </div>
        }
        else
        {
            <img class="size-8 sm:size-10 rounded-full flex-none object-cover"
                 src="@(Conversation.ImageUrl ?? "/images/user-avatar.png")"
                 alt="">
            <div class="min-w-0 flex-1">
                <div class="font-semibold truncate text-sm sm:text-base" style="color: var(--text);">@Conversation.Title</div>
            </div>
        }
        <Button Clicked="OnOpenInfo" 
                class="flex-none px-2 py-1.5 sm:py-1 rounded transition-colors hover:opacity-70"
                Style="color: var(--text);">
            <Icon Name="IconName.InfoCircle" Size="IconSize.Small"/>
        </Button>
    </div>
</header>

@code{
    [Parameter] public required ConversationDto Conversation { get; set; }
    [Parameter] public EventCallback OnOpenInfo { get; set; }
    [Parameter] public required string CurrentUserId { get; set; }
}
