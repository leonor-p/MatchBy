@page "/users"
@inject IUsersService UsersService
@inject NavigationManager NavigationManager
@using System.Security.Claims
@using MatchBy.Models
@using MatchBy.Services.Users
@using MatchBy.Enums
@rendermode InteractiveServer
@using Blazorise
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<PageTitle>Users</PageTitle>

<section class="bg-[var(--background)] min-h-screen">
    <div class="max-w-screen-xl px-4 m-8 mx-auto">
        <h1 class="text-4xl font-bold text-[var(--main)] mb-6">
            Discover Players
        </h1>

        <div class="mb-6">
            <div class="relative">
                <div class="absolute left-3 top-1/2 transform -translate-y-1/2 pointer-events-none">
                    <svg class="w-5 h-5 text-[var(--text)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>

                <input type="text"
                       @bind="_searchTerm"
                       @bind:event="oninput"
                       @onkeyup="HandleSearchDebounced"
                       placeholder="Search users by name, username, or location..."
                       class="w-full pl-10 pr-10 py-3 bg-[var(--section-secondary)] text-[var(--text)] rounded-lg border-2 border-[var(--main)] focus:ring-2 focus:ring-[var(--main)] focus:border-transparent" />

                @if (!string.IsNullOrWhiteSpace(_searchTerm))
                {
                    <button @onclick="ClearSearch"
                            class="absolute right-3 top-1/2 transform -translate-y-1/2 text-[var(--text)] hover:text-[var(--main)]">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                    </button>
                }
            </div>

            @if (_users != null)
            {
                <p class="text-[var(--text)] mt-2 text-sm">
                    Showing @_users.Count of @_totalUsers @(_totalUsers == 1 ? "user" : "users")
                    @if (!string.IsNullOrWhiteSpace(_searchTerm))
                    {
                        <span>matching "@_searchTerm"</span>
                    }
                </p>
            }
        </div>

        @if (_loading)
        {
            <div class="flex justify-center items-center py-12">
                <Loading></Loading>
            </div>
        }
        else if (_users != null && _users.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var user in _users)
                {
                    <div @onclick="@(() => NavigateToProfile(user.Id))"
                         class="bg-[var(--section-secondary)] rounded-lg border-2 border-[var(--main)] p-4 cursor-pointer hover:shadow-lg transition-shadow duration-200 hover:border-[var(--main-hover)]">

                        <div class="flex flex-col items-center mb-3">
                            <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-[var(--main)] mb-2">
                                @if (user.ProfileImage != null)
                                {
                                    <img src="@user.ProfileImage.Url" alt="@user.DisplayName" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <img src="images/user-avatar.png" alt="@user.DisplayName" class="w-full h-full object-cover" />
                                }
                            </div>

                            <h3 class="font-semibold text-lg text-[var(--text)] text-center">
                                @user.DisplayName
                            </h3>
                            <p class="text-[var(--text)] text-sm opacity-75">&#64;@user.UserName</p>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(user.Bio))
                        {
                            <p class="text-[var(--text)] text-sm mb-3 line-clamp-2 text-center">
                                @user.Bio
                            </p>
                        }

                        @if (user.BaseLocation != null)
                        {
                            <div class="flex items-center justify-center text-[var(--text)] text-sm mb-2">
                                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                                </svg>
                                <span>@user.BaseLocation.City, @user.BaseLocation.Country</span>
                            </div>
                        }

                        @if (user.PreferredSports != null && user.PreferredSports.Any())
                        {
                            <div class="flex items-center justify-center gap-2 mb-3 flex-wrap">
                                @foreach (var sport in user.PreferredSports.Take(4))
                                {
                                    <div class="bg-[var(--section)] px-3 py-1 rounded border border-[var(--main)]">
                                        <span class="text-xs text-[var(--text)] font-medium">@sport.ToString()</span>
                                    </div>
                                }
                                @if (user.PreferredSports.Count > 4)
                                {
                                    <span class="text-[var(--text)] text-sm">+@(user.PreferredSports.Count - 4)</span>
                                }
                            </div>
                        }

                        <div class="flex items-center justify-between pt-3 border-t border-[var(--main)]">
                            @if (user.Rating > 0)
                            {
                                <div class="flex items-center text-yellow-400">
                                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                    <span class="font-semibold text-[var(--text)]">@user.Rating.ToString("F1")</span>
                                </div>
                            }

                            @if (user.JoinedMatches.Count > 0)
                            {
                                <div class="text-[var(--text)] text-sm">
                                    <span class="font-semibold">@user.JoinedMatches.Count</span> matches
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (_totalPages > 1)
            {
                <div class="flex justify-center items-center gap-2 mt-8">
                    <button @onclick="PreviousPage"
                            disabled="@(_currentPage == 1)"
                            class="px-4 py-2 rounded-md border-2 border-[var(--main)] text-[var(--text)] hover:bg-[var(--main)] hover:text-[var(--text-contrast)] disabled:opacity-50 disabled:cursor-not-allowed">
                        Previous
                    </button>

                    <div class="flex gap-1">
                        @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(_totalPages, _currentPage + 2); i++)
                        {
                            int pageNum = i;
                            <button @onclick="@(() => GoToPage(pageNum))"
                                    class="px-4 py-2 rounded-md border-2 @(pageNum == _currentPage ? "bg-[var(--main)] text-[var(--text-contrast)] border-[var(--main)]" : "border-[var(--main)] text-[var(--text)] hover:bg-[var(--main)] hover:text-[var(--text-contrast)]")">
                                @pageNum
                            </button>
                        }
                    </div>

                    <button @onclick="NextPage"
                            disabled="@(_currentPage == _totalPages)"
                            class="px-4 py-2 rounded-md border-2 border-[var(--main)] text-[var(--text)] hover:bg-[var(--main)] hover:text-[var(--text-contrast)] disabled:opacity-50 disabled:cursor-not-allowed">
                        Next
                    </button>
                </div>
            }
        }
        else if (!_loading)
        {
            <div class="flex flex-col items-center justify-center py-12">
                <svg class="w-24 h-24 text-[var(--text)] opacity-50 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <h3 class="text-xl font-semibold text-[var(--text)] mb-2">No users found</h3>
                <p class="text-[var(--text)] opacity-75">
                    @if (!string.IsNullOrWhiteSpace(_searchTerm))
                    {
                        <span>Try adjusting your search term</span>
                    }
                    else
                    {
                        <span>No users are currently available</span>
                    }
                </p>
            </div>
        }
    </div>
</section>

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12" />

@code {
    private List<ApplicationUser>? _users;
    private string _searchTerm = string.Empty;
    private bool _loading = true;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalUsers = 0;
    private readonly int _pageSize = 20;
    private System.Threading.Timer? _debounceTimer;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            _loading = true;
            StateHasChanged();

            var result = await UsersService.GetUsers(
                search: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                page: _currentPage,
                pageSize: _pageSize,
                CancellationToken.None);

            if (!result.Success || result.Data == null)
            {
                await ToastService.Error(result.ErrorMessages?.FirstOrDefault() ?? "Error loading users.");
                _users = new List<ApplicationUser>();
                return;
            }

            _users = result.Data.Data;
            _totalUsers = result.Data.TotalCount;
            _totalPages = (int)Math.Ceiling(_totalUsers / (double)_pageSize);
        }
        catch
        {
            await ToastService.Error("An error occurred while loading users.");
            _users = new List<ApplicationUser>();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void HandleSearchDebounced()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            _currentPage = 1;
            await InvokeAsync(async () =>
            {
                await LoadUsers();
            });
        }, null, 500, Timeout.Infinite);
    }

    private async Task ClearSearch()
    {
        _searchTerm = string.Empty;
        _currentPage = 1;
        await LoadUsers();
    }

    private void NavigateToProfile(string userId)
    {
        NavigationManager.NavigateTo($"/profile/{userId}");
    }

    private async Task PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadUsers();
        }
    }

    private async Task NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            await LoadUsers();
        }
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadUsers();
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
