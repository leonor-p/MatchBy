@using MatchBy.DTOs.Match

@if (Match is null)
{
    <div class="p-4 text-[var(--text)]">No data.</div>
}
else
{
    <a href="@($"/matches/{Match.Id}")"
       class="group h-full flex flex-row border bg-[var(--section)] shadow rounded-2xl border-2 border-[var(--main)] transition duration-200 ease-out hover:shadow-[0_0px_10px_-4px_var(--main)] rounded-lg shadow-sm overflow-hidden
              focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--main)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--section)]">

        <!-- Imagem -->
        <div class="md:basis-2/5 md:flex-none">
            <img class="object-cover w-full h-64 md:h-full rounded-t-lg md:rounded-none md:rounded-s-lg dark:hidden"
                 src="@GetMatchImage(false)"
                 alt="@($"{Match.Sport} image")"/>

            <img
                class="object-cover w-full h-64 md:h-full rounded-t-lg md:rounded-none md:rounded-s-lg hidden dark:block"
                src="@GetMatchImage(true)"
                alt="@($"{Match.Sport} image")"/>
        </div>

        <!-- Conteúdo -->
        <div class="md:basis-3/5 flex flex-col justify-between p-4 gap-3 leading-normal">

            <!-- Header: desporto, morada, data -->
            <div class="flex flex-col gap-1">
                <h5 class="text-xl font-bold tracking-tight text-[var(--main)]">
                    @Match.Sport
                </h5>

                <p class="text-sm font-normal text-[var(--text)] line-clamp-1">
                    @Match.Address
                </p>

                <p class="text-sm font-normal text-[var(--text)]">
                    @Match.MatchDateTimeUtc.ToLocalTime().ToString("dd/MM/yyyy - HH:mm")
                </p>
            </div>

            <!-- Ratings -->
            <div class="rounded-lg border border-[var(--main)]/20 bg-[var(--main)]/5 px-3 py-2">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex flex-col">
                        <span class="text-[0.65rem] font-semibold tracking-wide text-[var(--main)] uppercase">
                            Avg Rating
                        </span>
                        <span class="inline-flex items-center text-base font-semibold text-[var(--main)]">
                            @if (Match.AveragePlayersRating > 0)
                            {
                                <span>@(((int)Match.AveragePlayersRating).ToString())</span>
                                <svg class="w-5 h-5 ml-1 text-[var(--main)]" fill="currentColor" viewBox="0 0 20 20">
                                    <path
                                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                            }
                            else
                            {
                                <span class="text-xs text-[var(--text)]">N/A</span>
                            }
                        </span>
                    </div>

                    <span class="w-px h-10 bg-[var(--main)]/20"></span>

                    <div class="flex flex-col text-right">
                        <span class="text-[0.65rem] font-semibold tracking-wide text-[var(--main)] uppercase">
                            Min Required
                        </span>
                        <span class="inline-flex items-center text-base font-semibold text-[var(--main)]">
                            @if (Match.MinimumPlayersRating > 0)
                            {
                                <span>@(((int)Match.MinimumPlayersRating).ToString())</span>
                                <svg class="w-5 h-5 ml-1 text-[var(--main)]" fill="currentColor" viewBox="0 0 20 20">
                                    <path
                                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                            }
                            else
                            {
                                <span class="text-xs text-[var(--text)]">None</span>
                            }
                        </span>
                    </div>
                </div>
            </div>


            <!-- Descrição -->
            <p class="text-sm font-normal text-[var(--text)] line-clamp-2">
                @Match.Description
            </p>

            <!-- Jogadores -->
            <p class="mt-1 text-xs font-medium text-[var(--main)]">
                Players: @Match.Participants.Count / @Match.MaxPlayers
            </p>
        </div>
    </a>
}

@code {
    [Parameter] public MatchDto? Match { get; set; }

    private string GetMatchImage(bool isDarkMode) =>
        (Match?.Sport, isDarkMode) switch
        {
            (Sports.Football, false) => "/images/sports/light/football.avif",
            (Sports.Football, true) => "/images/sports/dark/football.avif",

            (Sports.Basketball, false) => "/images/sports/light/basketball.avif",
            (Sports.Basketball, true) => "/images/sports/dark/basketball.avif",

            (Sports.Tennis, false) => "/images/sports/light/tennis.avif",
            (Sports.Tennis, true) => "/images/sports/dark/tennis.avif",

            (Sports.Volleyball, false) => "/images/sports/light/volleyball.avif",
            (Sports.Volleyball, true) => "/images/sports/dark/volleyball.avif",

            (Sports.Paddle, false) => "/images/sports/light/paddle.avif",
            (Sports.Paddle, true) => "/images/sports/dark/paddle.avif",

            (Sports.Rugby, false) => "/images/sports/light/rugby.avif",
            (Sports.Rugby, true) => "/images/sports/dark/rugby.avif",

            (_, false) => "/images/sports/light/default.avif",
            (_, true) => "/images/sports/dark/default.avif"
        };

}
