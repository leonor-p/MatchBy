@page "/Matches"
@using System.ComponentModel
@using System.Security.Claims
@using MatchBy.DTOs.Match
@using MatchBy.Services.Matches
@using Blazorise
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@inject IMatchesService MatchesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable
@inject NavigationManager NavigationManager

@if (_viewModel is null)
{
    <div class="min-h-screen flex items-center justify-center bg-[var(--background)]">
        <Loading></Loading>
    </div>
}
else
{
    var viewModel = _viewModel!;
    <div class="min-h-screen p-8 bg-[var(--background)]">
        <div class="max-w-7xl mx-auto">
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                    <li class="inline-flex items-center">
                        <a href="/"
                           class="inline-flex items-center text-sm font-medium text-[var(--text)] hover:text-fg-brand">
                            <svg class="w-4 h-4 me-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24"
                                 height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="m4 12 8-8 8 8M6 10.5V19a1 1 0 0 0 1 1h3v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h3a1 1 0 0 0 1-1v-8.5"/>
                            </svg>
                            Home
                        </a>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center space-x-1.5">
                            <svg class="w-3.5 h-3.5 rtl:rotate-180 text-[var(--text)]" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="m9 5 7 7-7 7"/>
                            </svg>
                            <span class="inline-flex items-center text-sm font-medium text-[var(--text)]">Matches</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <!-- Header -->
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h1 class="text-4xl font-bold mb-2 text-[var(--text)]">Matches</h1>
                    <p class="text-[var(--text)] opacity-70">Find your next match or create one to get started</p>
                </div>
                <div class="flex gap-3">
                    <a href="/matches/create"
                       class="px-6 py-3 rounded-lg font-medium flex items-center gap-2 transition-colors border-2 border-[var(--main)] text-[var(--text)] hover:bg-[var(--section-secondary)]">
                        <span class="text-xl">+</span>
                        Create Match
                    </a>
                </div>
            </div>

            <!-- Toggle Tabs -->
            <div class="flex gap-4 mb-8">
                <button
                    class="@(_viewModel.ActiveTab == "my" ? "bg-[var(--section-secondary)] border-2 border-[var(--main)]" : "bg-[var(--section)] border-2 border-transparent") px-8 py-3 rounded-lg font-medium text-[var(--text)] hover:bg-[var(--section-secondary)] transition-all"
                    @onclick='() => UpdateUrl("my")'>
                    My Matches
                </button>
                <button
                    class="@(_viewModel.ActiveTab == "search" ? "bg-[var(--section-secondary)] border-2 border-[var(--main)]" : "bg-[var(--section)] border-2 border-transparent") px-8 py-3 rounded-lg font-medium text-[var(--text)] hover:bg-[var(--section-secondary)] transition-all"
                    @onclick='() => UpdateUrl("search")'>
                    Search Matches
                </button>
            </div>

            @if (_viewModel.ActiveTab == "my")
            {
                if (viewModel.IsAuthenticated)
                {
                    <!-- Matches I Created -->
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 text-[var(--text)]">Matches I Created</h2>
                        @if (viewModel.YourCreatedMatches is not null && viewModel.YourCreatedMatches.Count == 0)
                        {
                            <div
                                class="rounded-xl border border-[var(--main)] p-16 text-center bg-[var(--section-secondary)]">
                                <p class="mb-6 text-[var(--text)] opacity-70">You haven't created any match yet</p>
                                <a href="/matches/create"
                                   class="px-6 py-3 rounded-lg font-medium inline-flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)] hover:text-[var(--text)]">
                                    <span class="text-xl">+</span>
                                    Create First Match
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                @if (viewModel.YourCreatedMatches is null)
                                {
                                    <Loading
                                        Class="col-span-full min-h-[200px] flex items-center justify-center"></Loading>
                                }
                                else
                                {
                                    foreach (var match in viewModel.YourCreatedMatches)
                                    {
                                        <div class="max-w-[405px] mx-auto">
                                            <MatchCard Match="@match"/>
                                        </div>
                                    }
                                }
                            </div>
                            @if (viewModel is { YourCreatedMatchesPagination: not null, YourCreatedMatches.Count: > 0 })
                            {
                                <div class="flex justify-center mt-8">
                                    <OffsetPagination CurrentPage="@viewModel.CurrentPageCreatedMatches"
                                                      OnPageChanged="@OnPageChangedCreatedMatches"
                                                      PageSize="@(viewModel.YourCreatedMatchesPagination?.PageSize ?? 6)"
                                                      TotalItems="@(viewModel.YourCreatedMatchesPagination?.TotalCount ?? 0)"></OffsetPagination>
                                </div>
                            }
                        }
                    </div>

                    <!-- Matches I'm Attending -->
                    <div>
                        <h2 class="text-2xl font-bold mb-6 text-[var(--text)]">Matches I'm Attending</h2>
                        @if (viewModel.AttendingMatches is not null && viewModel.AttendingMatches.Count == 0)
                        {
                            <div
                                class="rounded-xl border border-[var(--main)] p-16 text-center bg-[var(--section-secondary)]">
                                <p class="mb-6 text-[var(--text)] opacity-70">You're not attending any matches yet</p>
                                <button @onclick='() => UpdateUrl("search")'
                                   class="px-6 py-3 rounded-lg font-medium inline-flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)] hover:text-[var(--text)]">
                                    <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                         width="24"
                                         height="24" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-width="2"
                                              d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
                                    </svg>
                                    Search Matches
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                @if (viewModel.AttendingMatches is null)
                                {
                                    <Loading
                                        Class="col-span-full min-h-[200px] flex items-center justify-center"></Loading>
                                }
                                else
                                {
                                    foreach (var match in viewModel.AttendingMatches)
                                    {
                                        <div class="max-w-[405px] mx-auto">
                                            <MatchCard Match="@match"/>
                                        </div>
                                    }
                                }
                            </div>
                            @if (viewModel is { AttendingMatchesPagination: not null, AttendingMatches.Count: > 0 })
                            {
                                <div class="flex justify-center mt-8">
                                    <OffsetPagination CurrentPage="@viewModel.CurrentPageAttendingMatches"
                                                      OnPageChanged="@OnPageChangedAttendingMatches"
                                                      PageSize="@(viewModel.AttendingMatchesPagination?.PageSize ?? 6)"
                                                      TotalItems="@(viewModel.AttendingMatchesPagination?.TotalCount ?? 0)"></OffsetPagination>
                                </div>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-xl border border-[var(--main)] p-16 text-center bg-[var(--section-secondary)]">
                        <p class="mb-6 text-[var(--text)] opacity-70">Please log in to view your matches</p>
                        <a href="/account/login"
                           class="px-6 py-3 rounded-lg font-medium inline-flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)] hover:text-[var(--text)]">
                            Log In
                        </a>
                    </div>
                }
            }
            else
            {
                <SearchMatches></SearchMatches>
            }

        </div>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "tab")] public string? Tab { get; set; }
    private MatchesViewModel? _viewModel;
    private PropertyChangedEventHandler? _propertyChangedHandler;

    protected override void OnInitialized()
    {
        _viewModel = new MatchesViewModel(MatchesService);
        _propertyChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        _viewModel.PropertyChanged += _propertyChangedHandler;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (_viewModel != null)
        {
            await _viewModel.InitializeAsync(userId, isAuthenticated);
        }
    }

    protected override void OnParametersSet() 
    {
        if (_viewModel != null && Tab is not null)
        {
            _viewModel.ActiveTab = Tab;
        }
    }

    private async Task OnPageChangedCreatedMatches(int page)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnPageChangedAsync(page, MatchesPageType.CreatedMatches);
    }

    private async Task OnPageChangedAttendingMatches(int page)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnPageChangedAsync(page, MatchesPageType.AttendingMatches);
    }
    
    void UpdateUrl(string tab)
    {
        var uri = NavigationManager.GetUriWithQueryParameters(
            new Dictionary<string, object?>
            {
                ["tab"] = string.IsNullOrWhiteSpace(tab) ? null : tab
            });

        NavigationManager.NavigateTo(uri, replace: true);
    }

    public void Dispose()
    {
        if (_viewModel != null && _propertyChangedHandler != null)
        {
            _viewModel.PropertyChanged -= _propertyChangedHandler;
        }
    }

}