@page "/matches/edit/{id}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@inject IMatchesService MatchesService
@inject IUsersService UsersService
@inject IMatchesInvitesService MatchesInvitesService
@inject NavigationManager NavigationManager
@using System.ComponentModel
@using Blazorise
@using System.Security.Claims
@using FluentValidation
@using MatchBy.DTOs.Match
@using MatchBy.Services.Matches
@using MatchBy.Services.MatchInvites
@using MatchBy.Services.Users
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime Js
@inject AuthenticationStateProvider AuthStateProvider
@inject IValidator<UpdateMatchDto> UpdateMatchDtoValidator
@inject IToastService ToastService
@implements IDisposable

@if (_viewModel?.Model is null || _viewModel.IsLoading || _tz is null)
{
    <div class="flex items-center justify-center min-h-screen">
        <Loading></Loading>
    </div>
}
else
{
    var viewModel = _viewModel!;
    var model = viewModel.Model!;
    <div class="min-h-screen bg-[var(--background)] px-4 py-8">
        <div class="max-w-5xl mx-auto">
            <button @onclick="@(() => NavigationManager.NavigateTo($"/matches/{Id}"))"
                    class="flex items-center gap-2 text-[var(--text)] hover:text-[var(--main)] mb-6 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Match
            </button>

            <div
                class="relative overflow-hidden rounded-3xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 md:p-8 mb-8">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between relative z-10">
                    <div>
                        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mt-2">Edit Match</h1>
                        <p class="text-[var(--text)] mt-3 max-w-2xl">
                            Update details, manage participants, and send invites.
                        </p>
                    </div>
                </div>
                <div
                    class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-[var(--main)]/15 via-transparent to-transparent pointer-events-none"></div>
            </div>

            <div class="grid gap-8">
                <div class="space-y-6">
                    <Validations @ref="@_validations" Mode="ValidationMode.Manual" ValidateOnLoad="false">
                        <div class="space-y-6">
                            <!-- Step 1: Location & Details -->
                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-6">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 1</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Match Details</h3>
                                    </div>
                                </div>

                                <div class="space-y-4">
                                    <FieldLabel> Choose the match location by clicking on the map:</FieldLabel>
                                    <div id="matchMap"
                                         class="w-full h-[180px] mt-2 sm:h-64 md:h-80 lg:h-[480px] rounded-lg border-3 border-[var(--main)] shadow-sm z-0"></div>

                                    @* HIDDEN LOCATION FIELDS *@
                                    <div style="display:none">
                                        <Validation Validator="@ValidateLatitude">
                                            <Field>
                                                <FieldLabel>Latitude</FieldLabel>
                                                <FieldBody>
                                                    <NumericEdit TValue="double" Value="@model.Location.Latitude"
                                                                 ValueChanged="@(v => _viewModel.Model = model with { Location = model.Location with { Latitude = v } })">
                                                        <Feedback>
                                                            <ValidationError/>
                                                        </Feedback>
                                                    </NumericEdit>
                                                </FieldBody>
                                            </Field>
                                        </Validation>
                                        <Validation Validator="@ValidateLongitude">
                                            <Field>
                                                <FieldLabel>Longitude</FieldLabel>
                                                <FieldBody>
                                                    <NumericEdit TValue="double" Value="@model.Location.Longitude"
                                                                 ValueChanged="@(v => _viewModel.Model = model with { Location = model.Location with { Longitude = v } })">
                                                        <Feedback>
                                                            <ValidationError/>
                                                        </Feedback>
                                                    </NumericEdit>
                                                </FieldBody>
                                            </Field>
                                        </Validation>
                                        <Validation Validator="@ValidateCity">
                                            <Field>
                                                <FieldLabel>City</FieldLabel>
                                                <FieldBody>
                                                    <TextEdit Text="@model.Location.City"
                                                              TextChanged="@(v => _viewModel.Model = model with { Location = model.Location with { City = v } })">
                                                        <Feedback>
                                                            <ValidationError/>
                                                        </Feedback>
                                                    </TextEdit>
                                                </FieldBody>
                                            </Field>
                                        </Validation>
                                        <Validation Validator="@ValidateCountry">
                                            <Field>
                                                <FieldLabel>Country</FieldLabel>
                                                <FieldBody>
                                                    <TextEdit Text="@model.Location.Country"
                                                              TextChanged="@(v => _viewModel.Model = model with { Location = model.Location with { Country = v } })">
                                                        <Feedback>
                                                            <ValidationError/>
                                                        </Feedback>
                                                    </TextEdit>
                                                </FieldBody>
                                            </Field>
                                        </Validation>
                                    </div>

                                    <Validation Validator="@ValidateAddress">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Address</FieldLabel>
                                            <FieldBody>
                                                <TextEdit Placeholder="Type your match address"
                                                          Text="@model.Address"
                                                          TextChanged="@(v =>
                                                                       {
                                                                           viewModel.UpdateAddress(v);
                                                                           StateHasChanged();
                                                                       })"
                                                          @onblur="@OnAddressBlur"
                                                          Class="w-full"
                                                          Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                    <Feedback>
                                                        <ValidationError/>
                                                    </Feedback>
                                                </TextEdit>
                                            </FieldBody>
                                        </Field>
                                    </Validation>

                                    <Validation Validator="@ValidateDescription">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Description
                                            </FieldLabel>
                                            <FieldBody>
                                                <TextEdit Placeholder="Type a description for your match"
                                                          Text="@model.Description"
                                                          TextChanged="@(v =>
                                                                       {
                                                                           viewModel.UpdateDescription(v);
                                                                           StateHasChanged();
                                                                       })"
                                                          Class="w-full"
                                                          Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                    <Feedback>
                                                        <ValidationError/>
                                                    </Feedback>
                                                </TextEdit>
                                            </FieldBody>
                                        </Field>
                                    </Validation>

                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <Validation Validator="@ValidatePrivacy">
                                            <Field>
                                                <FieldLabel class="text-[var(--text)] font-medium mb-2">Privacy
                                                </FieldLabel>
                                                <FieldBody>
                                                    <Select TValue="MatchPrivacy"
                                                            SelectedValue="@model.Privacy"
                                                            SelectedValueChanged="@(v =>
                                                                                  {
                                                                                      viewModel.UpdatePrivacy(v);
                                                                                      StateHasChanged();
                                                                                  })"
                                                            Class="w-full"
                                                            Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                        @foreach (var item in Enum.GetValues<MatchPrivacy>())
                                                        {
                                                            <SelectItem Value="@item">@item.ToString()</SelectItem>
                                                        }
                                                    </Select>
                                                </FieldBody>
                                            </Field>
                                        </Validation>

                                        <Validation Validator="@ValidateMatchDate">
                                            <Field>
                                                <FieldLabel class="text-[var(--text)] font-medium mb-2">Match DateTime
                                                </FieldLabel>
                                                <DatePicker TValue="DateTime"
                                                            InputMode="DateInputMode.DateTime"
                                                            DefaultHour="9"
                                                            DefaultMinute="15"
                                                            TimeAs24hr="true"
                                                            Placeholder="DD/MM/YYYY - HH:mm"
                                                            Date="@LocalMatchDate"
                                                            DateChanged="@(v => LocalMatchDate = v)"
                                                            Class="w-full !bg-[var(--background)] border !border-[var(--main)] !text-[var(--text)]"
                                                            Style=" color: var(--text); border-radius: 0.65rem; padding: 0.85rem;">
                                                    <Feedback>
                                                        <ValidationError/>
                                                    </Feedback>
                                                </DatePicker>
                                            </Field>
                                        </Validation>
                                    </div>
                                </div>
                            </section>

                            <!-- Step 2: Manage Participants -->
                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-6">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 2</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Participants</h3>
                                        <p class="text-sm text-[var(--text)]">Manage current participants.</p>
                                    </div>
                                </div>

                                @if (viewModel.CurrentMatchParticipants.Count > 0)
                                {
                                    <div
                                        class="space-y-2 max-h-60 overflow-y-auto border-2 border-[var(--main)] rounded-xl p-3 thin-scroll"
                                        style="background-color: var(--background);">
                                        @foreach (var user in viewModel.CurrentMatchParticipants)
                                        {
                                            var isCreator = user.Id == viewModel.UserId;
                                            var photoUrl = user.AvatarUrl ?? "/images/user-avatar.png";

                                            <div class="flex items-center justify-between py-2 px-3 rounded-lg"
                                                 style="color: var(--text);">
                                                <div class="flex items-center gap-3">
                                                    <img src="@photoUrl" alt="@user.DisplayName"
                                                         class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]"/>
                                                    <div>
                                                        <span class="font-medium">@user.DisplayName</span>
                                                        @if (isCreator)
                                                        {
                                                            <span
                                                                class="text-xs ml-2 px-2 py-1 bg-[var(--main)] rounded-full text-[var(--text-contrast)]">Creator</span>
                                                        }
                                                    </div>
                                                </div>
                                                @if (!isCreator)
                                                {
                                                    <button
                                                        @onclick="@(() => viewModel.RemoveParticipantAsync(user.Id))"
                                                        class="px-3 py-1 bg-[var(--error)] hover:opacity-80 text-white rounded-lg text-sm font-medium transition">
                                                        Remove
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="py-4 text-center opacity-60 border-2 border-[var(--main)] rounded-lg"
                                         style="color: var(--text); background-color: var(--background);">
                                        No participants yet
                                    </div>
                                }
                            </section>

                            <!-- Step 3: Manage Invites -->
                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-6">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 3</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Manage Invites</h3>
                                        <p class="text-sm text-[var(--text)]">Review pending invites and send new
                                            ones.</p>
                                    </div>
                                </div>

                                @if (viewModel.PendingInvites.Count > 0)
                                {
                                    <div class="flex items-center justify-between">
                                        <h4 class="text-lg font-semibold text-[var(--text)]">Pending invites
                                            (@(viewModel.PendingInvites?.Count ?? 0))</h4>
                                    </div>
                                    @if (viewModel.IsLoadingInvites)
                                    {
                                        <Loading></Loading>
                                    }
                                    else if (viewModel.PendingInvites is { Count: > 0 })
                                    {
                                        <div
                                            class="space-y-2 max-h-60 overflow-y-auto border-2 border-[var(--main)] rounded-xl p-3 thin-scroll"
                                            style="background-color: var(--background);">
                                            @foreach (var invite in viewModel.PendingInvites)
                                            {
                                                var photoUrl = invite.Receiver?.AvatarUrl ?? "/images/user-avatar.png";
                                                <div
                                                    class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-[var(--main)]/10 transition-all"
                                                    style="color: var(--text);">
                                                    <div class="flex items-center gap-3">
                                                        <img src="@photoUrl"
                                                             alt="@invite.Receiver?.DisplayName"
                                                             class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]"/>
                                                        <div>
                                                            <span
                                                                class="font-medium">@invite.Receiver?.DisplayName</span>
                                                            <div class="text-xs opacity-70">
                                                                Invited @invite.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                                        </div>
                                                    </div>
                                                    <button
                                                        @onclick="@(() => _viewModel.RemoveInviteAsync(invite.Id))"
                                                        class="px-3 py-1 bg-[var(--error)] hover:opacity-80 text-white rounded-lg text-sm font-medium transition">
                                                        Cancel
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div
                                            class="py-4 text-center opacity-60 border-2 border-[var(--main)] rounded-lg"
                                            style="color: var(--text); background-color: var(--background);">
                                            No pending invites
                                        </div>
                                    }
                                }

                                <!-- Send New Invites -->
                                <h4 class="text-lg font-semibold text-[var(--text)] mt-4">Invite New Players</h4>
                                <div class="mb-3">
                                    <TextEdit @bind-Text="viewModel.InviteSearch"
                                              @bind-Text:after="StateHasChanged"
                                              Placeholder="Search for users to invite"
                                              Role="TextRole.Search"
                                              KeyDown="@(async e => await viewModel.OnInviteSearchKeyDownAsync(e))"
                                              Class="w-full"
                                              Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;"/>
                                </div>

                                @if (viewModel.IsLoadingInviteUsers)
                                {
                                    <Loading></Loading>
                                }
                                else
                                {
                                    <div
                                        class="max-h-60 overflow-y-auto mb-3 border-2 border-[var(--main)] rounded-xl p-2 thin-scroll"
                                        style="background-color: var(--background);">
                                        @if ((viewModel.AvailableInviteUsers.Data?.Count ?? 0) == 0)
                                        {
                                            <div class="py-3 text-center opacity-60" style="color: var(--text);">No
                                                users found
                                            </div>
                                        }
                                        else
                                        {
                                            if (viewModel.AvailableInviteUsers.Data != null)
                                            {
                                                foreach (var user in viewModel.AvailableInviteUsers.Data)
                                                {
                                                    var isParticipant = viewModel.IsParticipant(user.Id);
                                                    var isInvited = viewModel.PendingInvites!.Any(i => i.ReceiverId == user.Id);

                                                    <div
                                                        class="flex items-center justify-between gap-3 py-2 px-3 rounded-lg transition-all hover:opacity-80 @(isParticipant || isInvited ? "opacity-50" : "")"
                                                        style="color: var(--text);">
                                                        <div class="flex items-center gap-3 flex-1">
                                                            <img src="@user.AvatarUrl" alt="@user.DisplayName"
                                                                 class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]"/>
                                                            <span class="fw-500 truncate">@user.DisplayName</span>
                                                        </div>
                                                        @if (isParticipant)
                                                        {
                                                            <span
                                                                class="text-xs px-2 py-1 bg-[var(--main)] rounded-full text-[var(--text-contrast)]">
                                                                Participant
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            if (isInvited)
                                                            {
                                                                <span
                                                                    class="text-xs px-2 py-1 bg-yellow-500 text-white rounded-full">
                                                                    Invited
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <button
                                                                    @onclick="@(() => viewModel.SendInviteToUserAsync(user.Id))"
                                                                    class="px-3 py-1 bg-[var(--main)] hover:opacity-80 text-[var(--text-contrast)] rounded-lg text-sm font-medium transition">
                                                                    Invite
                                                                </button>
                                                            }
                                                        }
                                                    </div>
                                                }
                                            }
                                        }
                                    </div>
                                    @if (viewModel.AvailableInviteUsers is { Data: not null, TotalCount: > 0 })
                                    {
                                        <div class="flex justify-center mt-2">
                                            <OffsetPagination CurrentPage="@viewModel.CurrentInvitePage"
                                                              OnPageChanged="@(async page => await viewModel.OnInvitePageChangedAsync(page))"
                                                              PageSize="10"
                                                              TotalItems="@viewModel.AvailableInviteUsers.TotalCount"/>
                                        </div>
                                    }
                                }
                            </section>

                            <section class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6">
                                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                                    <div>
                                        <h3 class="text-xl font-semibold text-[var(--text)]">Ready to update?</h3>
                                    </div>
                                    <Button Color="Color.Primary"
                                            Clicked="@SubmitMatch"
                                            Loading="@viewModel.IsSubmitting"
                                            Class="w-full md:w-auto"
                                            Style="background-color: var(--main); color: var(--text-contrast); padding: 0.9rem 2.4rem; border-radius: 0.75rem; font-weight: 600; transition: all 0.2s;">
                                        Save Changes
                                    </Button>
                                </div>
                            </section>
                        </div>
                    </Validations>
                </div>
            </div>
        </div>
    </div>
}

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>

@code {
    Validations _validations = null!;
    private EditMatchViewModel? _viewModel;
    private PropertyChangedEventHandler? _propertyChangedHandler;
    private string? _userId;
    private string? _tzId;
    private TimeZoneInfo? _tz;

    [Parameter] public string? Id { get; set; }

    private DateTime LocalMatchDate
    {
        get
        {
            if (_viewModel?.Model is null || _tz is null) return default;
            var utc = DateTime.SpecifyKind(_viewModel.Model.MatchDateTimeUtc, DateTimeKind.Utc);
            var local = Tz.ToLocal(utc, _tz);
            return DateTime.SpecifyKind(local, DateTimeKind.Unspecified);
        }
        set
        {
            if (_viewModel?.Model is null || _tz is null) return;
            var local = DateTime.SpecifyKind(value, DateTimeKind.Unspecified);
            var utc = Tz.ToUtc(local, _tz);
            _viewModel.Model = _viewModel.Model with { MatchDateTimeUtc = DateTime.SpecifyKind(utc, DateTimeKind.Utc) };
        }
    }

    private void ValidateProperty(ValidatorEventArgs e, string propertyPath)
    {
        if (_viewModel is null)
        {
            e.Status = ValidationStatus.Error;
            e.ErrorText = "Model not ready yet.";
            return;
        }

        var status = _viewModel.ValidateProperty(propertyPath);
        e.Status = status;
        if (status == ValidationStatus.Error)
        {
            e.ErrorText = _viewModel.GetValidationError(propertyPath);
        }
    }

    void ValidateLatitude(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Latitude)}");
    void ValidateLongitude(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Longitude)}");
    void ValidateCity(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.City)}");
    void ValidateCountry(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Country)}");
    void ValidateAddress(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Address));
    void ValidateDescription(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Description));
    void ValidatePrivacy(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Privacy));
    void ValidateMatchDate(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.MatchDateTimeUtc));

    private async Task SubmitMatch()
    {
        if (_viewModel is null) return;
        var success = await _viewModel.SubmitMatchAsync(_validations);
        if (success && Id is not null)
        {
            NavigationManager.NavigateTo($"/matches/{Id}");
        }
    }

    private async Task OnAddressBlur(FocusEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(_viewModel?.Model?.Address)) return;
        await Js.InvokeVoidAsync("geocodeAddress", _viewModel.Model.Address);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (_userId == null)
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        _viewModel = new EditMatchViewModel(MatchesService, UsersService, MatchesInvitesService, UpdateMatchDtoValidator, ToastService);
        _propertyChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        _viewModel.PropertyChanged += _propertyChangedHandler;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_viewModel is null || _userId is null) return;

        if (string.IsNullOrWhiteSpace(Id))
        {
            NavigationManager.NavigateTo("/404", forceLoad: true);
            return;
        }

        if (_viewModel.MatchId == Id && _viewModel.Model is not null && !_viewModel.IsLoading) return;

        var result = await _viewModel.InitializeAsync(Id, _userId);
        switch (result.Status)
        {
            case EditMatchLoadStatus.Success:
                break;
            case EditMatchLoadStatus.Unauthorized:
                await ToastService.Error(result.ErrorMessage ?? "You don't have permission to edit this match.");
                NavigationManager.NavigateTo($"/matches/{Id}");
                break;
            case EditMatchLoadStatus.NotFound:
            case EditMatchLoadStatus.Invalid:
                NavigationManager.NavigateTo("/404", forceLoad: true);
                break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _tzId = await Js.InvokeAsync<string>("timeZone");
        _tz = Tz.FromId(_tzId);

        await Js.InvokeVoidAsync("registerMatchComponent", DotNetObjectReference.Create(this));
        StateHasChanged();
    }

    [JSInvokable]
    public void UpdateLocationFromMap(double lat, double lng, string city, string country, string address)
    {
        if (_viewModel?.Model is null) return;

        _viewModel.Model = _viewModel.Model with
        {
            Location = new Location(Latitude: lat, Longitude: lng, City: city, Country: country),
            Address = address
        };
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_propertyChangedHandler != null && _viewModel != null)
        {
            _viewModel.PropertyChanged -= _propertyChangedHandler;
        }
    }

}
