@page "/EditMatch/{id}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IMatchesService MatchesService
@inject NavigationManager NavigationManager
@using Blazorise
@using System.Security.Claims
@using FluentValidation
@using MatchBy.DTOs.Match
@using MatchBy.Services.Matches
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime Js
@inject AuthenticationStateProvider AuthStateProvider
@inject IValidator<UpdateMatchDto> UpdateMatchDtoValidator

@if (_model is null || _tz is null)
{
    <Loading></Loading>
}
else
{
    <Div Margin="Margin.IsAuto.OnX" Padding="Padding.Is5.OnX" Width="Width.Is50" class="mt-8">
        <Heading Size="HeadingSize.Is2" Margin="Margin.Is3.FromBottom" Style="color: var(--main);">
            Edit Match
        </Heading>

        <Validations @ref="@_validations" Mode="ValidationMode.Manual" ValidateOnLoad="false">
            <Fields>
                <FieldLabel> Choose the match location by clicking on the map: </FieldLabel>
                <div id="matchMap" class="w-full h-[180px] mt-2 sm:h-64 md:h-80 lg:h-[480px] rounded-lg border-3 border-[var(--main)] shadow-sm"></div>

                @* HIDDEN LOCATION FIELDS *@
                <div style="display:none">
                    <Validation Validator="@ValidateLatitude">
                        <Field>
                            <FieldLabel>Latitude</FieldLabel>
                            <FieldBody>
                                <NumericEdit TValue="double"
                                            Value="@_model.Location.Latitude"
                                            ValueChanged="@(v => _model = _model with { Location = _model.Location with { Latitude = v } })">
                                    <Feedback>
                                        <ValidationError/>
                                    </Feedback>
                                </NumericEdit>
                            </FieldBody>
                        </Field>
                    </Validation>
                    <Validation Validator="@ValidateLongitude">
                        <Field>
                            <FieldLabel>Longitude</FieldLabel>
                            <FieldBody>
                                <NumericEdit TValue="double"
                                            Value="@_model.Location.Longitude"
                                            ValueChanged="@(v => _model = _model with { Location = _model.Location with { Longitude = v } })">
                                    <Feedback>
                                        <ValidationError/>
                                    </Feedback>
                                </NumericEdit>
                            </FieldBody>
                        </Field>
                    </Validation>
                    <Validation Validator="@ValidateCity">
                        <Field>
                            <FieldLabel>City</FieldLabel>
                            <FieldBody>
                                <TextEdit Text="@_model.Location.City"
                                        TextChanged="@(v => _model = _model with { Location = _model.Location with { City = v } })">
                                    <Feedback>
                                        <ValidationError/>
                                    </Feedback>
                                </TextEdit>
                            </FieldBody>
                        </Field>
                    </Validation>
                    <Validation Validator="@ValidateCountry">
                        <Field>
                            <FieldLabel>Country</FieldLabel>
                            <FieldBody>
                                <TextEdit Text="@_model.Location.Country"
                                        TextChanged="@(v => _model = _model with { Location = _model.Location with { Country = v } })">
                                    <Feedback>
                                        <ValidationError/>
                                    </Feedback>
                                </TextEdit>
                            </FieldBody>
                        </Field>
                    </Validation>
                </div>
            </Fields>

            <Validation Validator="@ValidateAddress">
                <Field>
                    <FieldLabel>Address</FieldLabel>
                    <FieldBody>
                        <TextEdit Placeholder="Type your match address" 
                                Text="@_model.Address"
                                TextChanged="@(v => _model = _model with { Address = v })"
                                @onblur="@OnAddressBlur">
                            <Feedback>
                                <ValidationError/>
                            </Feedback>
                        </TextEdit>
                    </FieldBody>
                </Field>
            </Validation>

            <Validation Validator="@ValidateDescription">
                <Field>
                    <FieldLabel>Description</FieldLabel>
                    <FieldBody>
                        <TextEdit Placeholder="Type a description for your match" 
                                Text="@_model.Description"
                                TextChanged="@(v => _model = _model with { Description = v })">
                            <Feedback>
                                <ValidationError/>
                            </Feedback>
                        </TextEdit>
                    </FieldBody>
                </Field>
            </Validation>

            <Fields>
                <Validation Validator="@ValidateMinPlayers">
                    <Field ColumnSize="ColumnSize.IsFull.OnTablet.IsHalf.OnDesktop">
                        <FieldLabel>Min Players</FieldLabel>
                        <FieldBody>
                            <NumericEdit TValue="int" Placeholder="Min Players Number" 
                                        Value="@_model.MinPlayers"
                                        ValueChanged="@(v => _model = _model with { MinPlayers = v })">
                                <Feedback>
                                    <ValidationError/>
                                </Feedback>
                            </NumericEdit>
                        </FieldBody>
                    </Field>
                </Validation>

                <Validation Validator="@ValidateMaxPlayers">
                    <Field ColumnSize="ColumnSize.IsFull.OnTablet.IsHalf.OnDesktop">
                        <FieldLabel>Max Players</FieldLabel>
                        <FieldBody>
                            <NumericEdit TValue="int" Placeholder="Max Players Number" 
                                        Value="@_model.MaxPlayers"
                                        ValueChanged="@(v => _model = _model with { MaxPlayers = v })">
                                <Feedback>
                                    <ValidationError/>
                                </Feedback>
                            </NumericEdit>
                        </FieldBody>
                    </Field>
                </Validation>
            </Fields>

            <Fields>
                <Validation Validator="@ValidateSport">
                    <Field ColumnSize="ColumnSize.IsFull.OnTablet.IsThird.OnDesktop">
                        <FieldLabel>Sport</FieldLabel>
                        <FieldBody>
                            <Select TValue="Sports" 
                                    SelectedValue="@_model.Sport"
                                    SelectedValueChanged="@(v => _model = _model with { Sport = v })">
                                @foreach (var item in Enum.GetValues<Sports>())
                                {
                                    <SelectItem Value="@item">@item.ToString()</SelectItem>
                                }
                            </Select>
                        </FieldBody>
                    </Field>
                </Validation>

                <Validation Validator="@ValidatePrivacy">
                    <Field ColumnSize="ColumnSize.IsFull.OnTablet.IsThird.OnDesktop">
                        <FieldLabel>Privacy</FieldLabel>
                        <FieldBody>
                            <Select TValue="MatchPrivacy" 
                                    SelectedValue="@_model.Privacy"
                                    SelectedValueChanged="@(v => _model = _model with { Privacy = v })">
                                @foreach (var item in Enum.GetValues<MatchPrivacy>())
                                {
                                    <SelectItem Value="@item">@item.ToString()</SelectItem>
                                }
                            </Select>
                        </FieldBody>
                    </Field>
                </Validation>

                <Validation Validator="@ValidateMatchDate">
                    <Field ColumnSize="ColumnSize.IsFull.OnTablet.IsThird.OnDesktop">
                        <FieldLabel>MatchDateTime</FieldLabel>
                        <DatePicker TValue="DateTime"
                                    InputMode="DateInputMode.DateTime"
                                    DefaultHour="9"
                                    DefaultMinute="15"
                                    TimeAs24hr="true"
                                    Placeholder="DD/MM/YYYY - HH:mm"
                                    Date="@LocalMatchDate"
                                    DateChanged="@(v => LocalMatchDate = v)">
                            <Feedback>
                                <ValidationError/>
                            </Feedback>
                        </DatePicker>
                    </Field>
                </Validation>
            </Fields>

            <Field>
                <Button Color="Color.Primary" Clicked="@SubmitMatch" Loading="@_isLoading">
                    Update Match
                </Button>
            </Field>

        </Validations>
    </Div>
}

@code {
    Validations _validations = null!;
    UpdateMatchDto? _model;
    private string? _tzId;
    private TimeZoneInfo? _tz;
    private string? _userId;
    private bool _isLoading = true;

    [Parameter] public string? Id { get; set; }

    private DateTime LocalMatchDate
    {
        get
        {
            if (_model is null || _tz is null) return default;
            var utc = DateTime.SpecifyKind(_model.MatchDateTimeUtc, DateTimeKind.Utc);
            var local = Tz.ToLocal(utc, _tz);
            return DateTime.SpecifyKind(local, DateTimeKind.Unspecified);
        }
        set
        {
            if (_model is null || _tz is null) return;
            var local = DateTime.SpecifyKind(value, DateTimeKind.Unspecified);
            var utc = Tz.ToUtc(local, _tz);
            _model = _model with { MatchDateTimeUtc = DateTime.SpecifyKind(utc, DateTimeKind.Utc) };
        }
    }

    private void ValidateProperty(ValidatorEventArgs e, string propertyPath)
    {
        if (_model is null) return;
        
        var errors = UpdateMatchDtoValidator.Validate(_model).Errors
            .Where(x => x.PropertyName == propertyPath)
            .ToList();

        if (errors.Any())
        {
            e.Status = ValidationStatus.Error;
            e.ErrorText = errors[0].ErrorMessage;
        }
        else
        {
            e.Status = ValidationStatus.Success;
        }
    }

    void ValidateLatitude(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Latitude)}");
    void ValidateLongitude(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Longitude)}");
    void ValidateCity(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.City)}");
    void ValidateCountry(ValidatorEventArgs e) => ValidateProperty(e, $"{nameof(UpdateMatchDto.Location)}.{nameof(Location.Country)}");
    void ValidateAddress(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Address));
    void ValidateDescription(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Description));
    void ValidateMinPlayers(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.MinPlayers));
    void ValidateMaxPlayers(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.MaxPlayers));
    void ValidateMatchDate(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.MatchDateTimeUtc));
    void ValidateSport(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Sport));
    void ValidatePrivacy(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateMatchDto.Privacy));

    private async Task SubmitMatch()
    {
        if (_model is null || !await _validations.ValidateAll()) return;

        var result = await MatchesService.UpdateMatch(_model);

        if (!result.Success)
        {
            Console.WriteLine($"Error updating match: {result.ErrorMessages}");
            return;
        }

        NavigationManager.NavigateTo("/Matches");
    }

    private async Task OnAddressBlur(FocusEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(_model?.Address)) return;
        await Js.InvokeVoidAsync("geocodeAddress", _model.Address);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _userId = user.FindFirst(ClaimTypes.NameIdentifier)!.Value;
    }

    protected override async Task OnParametersSetAsync()
    {
        if(_userId is null)
        {
            return;
        }
        
        if (Id is null)
        {
            NavigationManager.NavigateTo("/404", forceLoad: true);
            return;
        }

        var result = await MatchesService.GetMatchById(Id, _userId, CancellationToken.None);
        
        if (!result.Success || result.Data is null)
        {
            NavigationManager.NavigateTo("/404", forceLoad: true);
            return;
        }

        var match = result.Data;
        _model = new UpdateMatchDto
        {
            MatchId = Id,
            Location = match.Location,
            MatchDateTimeUtc = match.MatchDateTimeUtc,
            Address = match.Address,
            Description = match.Description,
            Privacy = match.Privacy,
            Sport = match.Sport,
            MinPlayers = match.MinPlayers,
            MaxPlayers = match.MaxPlayers,
            UserId = _userId
        };

        _isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _tzId = await Js.InvokeAsync<string>("timeZone");
        _tz = Tz.FromId(_tzId);

        await Js.InvokeVoidAsync("registerMatchComponent", DotNetObjectReference.Create(this));
        StateHasChanged();
    }

    [JSInvokable]
    public void UpdateLocationFromMap(double lat, double lng, string city, string country, string address)
    {
        if (_model is null) return;
        
        _model = _model with 
        { 
            Location = new Location(Latitude: lat, Longitude: lng, City: city, Country: country),
            Address = address
        };
        InvokeAsync(StateHasChanged);
    }
}