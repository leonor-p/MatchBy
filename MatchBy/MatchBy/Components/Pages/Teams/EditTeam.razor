@page "/teams/edit/{id}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@inject ITeamService TeamService
@inject IUsersService UsersService
@inject ITeamsInvitesService TeamInvitesService
@inject NavigationManager NavigationManager
@using System.ComponentModel
@using Blazorise
@using System.Linq
@using System.Security.Claims
@using FluentValidation
@using MatchBy.DTOs.Team
@using MatchBy.Services.Teams
@using MatchBy.Services.TeamInvites
@using MatchBy.Services.Users
@using Microsoft.AspNetCore.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IValidator<UpdateTeamDto> UpdateTeamDtoValidator
@inject IToastService ToastService

@if (_viewModel is null || _viewModel.Model is null || _viewModel.IsLoading)
{
    <div class="flex items-center justify-center min-h-screen">
        <Loading></Loading>
    </div>
}
else
{
    var viewModel = _viewModel!;
    var model = viewModel.Model!;
    <div class="min-h-screen bg-[var(--background)] px-4 py-8">
        <div class="max-w-5xl mx-auto">
            <button @onclick="@(() => NavigationManager.NavigateTo($"/teams/{Id}"))"
                    class="flex items-center gap-2 text-[var(--text)] hover:text-[var(--main)] mb-6 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to team
            </button>

            <div
                class="relative overflow-hidden rounded-3xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 md:p-8 mb-8">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between relative z-10">
                    <div>
                        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mt-2">Edit your team</h1>
                        <p class="text-[var(--text)] mt-3 max-w-2xl">
                            Update your team&apos;s information, manage members, all in one place.
                        </p>
                    </div>
                </div>
                <div
                    class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-[var(--main)]/15 via-transparent to-transparent pointer-events-none"></div>
            </div>

            <div class="grid gap-8">
                <div class="space-y-6">
                    <Validations @ref="@_validations" Mode="ValidationMode.Manual" ValidateOnLoad="false">
                        <div class="space-y-6">
                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-6">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 1</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Team basics</h3>
                                        <p class="text-sm text-[var(--text)]">
                                            Name your team, describe what you do, and confirm who can find you.
                                        </p>
                                    </div>
                                    <span
                                        class="inline-flex items-center rounded-full bg-[var(--main)]/10 text-[var(--main)] px-3 py-1 text-xs font-semibold">
                                        Required
                                    </span>
                                </div>

                                <div class="space-y-4">
                                    <Validation Validator="@ValidateName">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Team name
                                            </FieldLabel>
                                            <FieldBody>
                                                <TextEdit Placeholder="Enter team name"
                                                          Text="@model.Name"
                                                          TextChanged="@(v => viewModel.UpdateName(v))"
                                                          Class="w-full"
                                                          Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                    <Feedback>
                                                        <ValidationError/>
                                                    </Feedback>
                                                </TextEdit>
                                            </FieldBody>
                                        </Field>
                                    </Validation>

                                    <Validation Validator="@ValidateDescription">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Description
                                            </FieldLabel>
                                            <FieldBody>
                                                <TextEdit Placeholder="Share your mission, cadence, or requirements"
                                                          Text="@model.Description"
                                                          TextChanged="@(v => viewModel.UpdateDescription(v))"
                                                          Class="w-full"
                                                          Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                    <Feedback>
                                                        <ValidationError/>
                                                    </Feedback>
                                                </TextEdit>
                                            </FieldBody>
                                        </Field>
                                    </Validation>

                                    <Validation Validator="@ValidatePrivacy">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Privacy</FieldLabel>
                                            <FieldBody>
                                                <Select TValue="TeamPrivacy"
                                                        SelectedValue="@model.Privacy"
                                                        SelectedValueChanged="@(v => viewModel.UpdatePrivacy(v))"
                                                        Class="w-full"
                                                        Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;">
                                                    @foreach (var item in Enum.GetValues<TeamPrivacy>())
                                                    {
                                                        <SelectItem Value="@item">@item.ToString()</SelectItem>
                                                    }
                                                </Select>
                                            </FieldBody>
                                        </Field>
                                    </Validation>
                                </div>
                            </section>

                            <div class="grid gap-6 lg:grid-cols-[3fr_2fr]">
                                <section
                                    class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 2</p>
                                            <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Branding</h3>
                                            <p class="text-sm text-[var(--text)]">Upload a refreshed image so teammates
                                                can spot you instantly.</p>
                                        </div>
                                    </div>

                                    <div class="space-y-3">
                                        <Field>
                                            <FieldLabel class="text-[var(--text)] font-medium mb-2">Team image
                                            </FieldLabel>
                                            <FieldBody>
                                                <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                                                    <InputFile OnChange="HandleImageChanged"
                                                               accept="image/*"
                                                               class="block w-full text-sm text-[var(--text)] border-2 border-dashed border-[var(--main)] rounded-xl cursor-pointer bg-[var(--background)] focus:outline-none focus:border-[var(--main)] file:mr-4 file:py-2.5 file:px-4 file:rounded-l-xl file:border-0 file:text-sm file:font-semibold file:bg-[var(--main)] file:text-[var(--text-contrast)] hover:file:opacity-80"/>
                                                    @if (viewModel.SelectedImage != null || !string.IsNullOrEmpty(viewModel.ImagePreviewSource))
                                                    {
                                                        <button type="button"
                                                                @onclick="RemoveImage"
                                                                class="inline-flex items-center justify-center px-4 py-2 rounded-lg text-sm font-medium bg-[var(--error)] text-[var(--text-contrast)] hover:opacity-90 transition">
                                                            Remove
                                                        </button>
                                                    }
                                                </div>
                                                <p class="text-xs text-[var(--text)] mt-2">
                                                    Supported formats: JPG, JPEG, PNG. Max size 5MB for previews.
                                                </p>
                                            </FieldBody>
                                        </Field>
                                    </div>
                                </section>

                                <div
                                    class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] flex-1 flex items-center justify-center overflow-hidden max-h-[360px]">
                                    @if (!string.IsNullOrEmpty(viewModel.ImagePreviewSource))
                                    {
                                        <img src="@viewModel.ImagePreviewSource"
                                             alt="Team image preview"
                                             class="w-full h-full object-cover max-h-[360px]">
                                    }
                                    else
                                    {
                                        <div class="text-center text-[var(--text)] space-y-2 p-6">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 stroke-linecap="round" stroke-linejoin="round"
                                                 class="w-10 h-10 mx-auto lucide lucide-image-icon lucide-image text-[var(--text)]">
                                                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                                                <circle cx="9" cy="9" r="2"/>
                                                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                                            </svg>
                                            <p class="text-sm font-medium text-[var(--text)]">Your preview will appear
                                                here</p>
                                            <p class="text-xs text-[var(--text)]">Upload an image above to bring your
                                                team to life.</p>
                                        </div>
                                    }
                                </div>
                            </div>

                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 3</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Manage members</h3>
                                        <p class="text-sm text-[var(--text)]">Search, toggle, and trim your active
                                            roster.</p>
                                    </div>
                                </div>

                                <Field>
                                    <FieldBody>
                                        <div class="mb-3">
                                            <TextEdit @bind-Text="viewModel.MemberSearch"
                                                      @bind-Text:after="StateHasChanged"
                                                      Placeholder="Search for users to add"
                                                      Role="TextRole.Search"
                                                      KeyDown="@(async e => await viewModel.OnMemberSearchKeyDownAsync(e))"
                                                      Class="w-full"
                                                      Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;"/>
                                        </div>

                                        @if (viewModel.IsLoadingMembers)
                                        {
                                            <Loading></Loading>
                                        }
                                        else if (model.MembersIds.Any(m => m != viewModel.UserId))
                                        {
                                            <div
                                                class="max-h-60 overflow-y-auto mb-3 border-2 border-[var(--main)] rounded-xl p-2 thin-scroll"
                                                style="background-color: var(--background);">
                                                @if ((viewModel.AvailableUsers.Data?.Count ?? 0) == 0)
                                                {
                                                    <div class="py-3 text-center opacity-60"
                                                         style="color: var(--text);">No users found
                                                    </div>
                                                }
                                                else
                                                {
                                                    if (viewModel.AvailableUsers.Data != null)
                                                    {
                                                        foreach (var user in viewModel.AvailableUsers.Data)
                                                        {
                                                            var isSelected = viewModel.SelectedMemberIds.Contains(user.Id);
                                                            <div
                                                                class="flex items-center gap-3 py-2 px-3 rounded-xl transition-all text-[var(--text)] hover:bg-[var(--main)] hover:text-[var(--text-contrast)] cursor-pointer"
                                                                @onclick="@(() => viewModel.ToggleMember(user.Id))">
                                                                <img src="@user.AvatarUrl"
                                                                     alt="@user.DisplayName"
                                                                     class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]/60"/>
                                                                <span
                                                                    class="fw-500 truncate flex-1">
                                                                    @user.DisplayName
                                                                </span>
                                                                @if (isSelected)
                                                                {
                                                                    <svg class="w-5 h-5 flex-shrink-0" fill="currentColor"
                                                                         viewBox="0 0 20 20">
                                                                        <path fill-rule="evenodd"
                                                                              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                                              clip-rule="evenodd"/>
                                                                    </svg>
                                                                }
                                                            </div>
                                                        }
                                                    }
                                                }
                                            </div>

                                            if (viewModel.AvailableUsers is { Data: not null, TotalCount: > 0 })
                                            {
                                                <div class="flex justify-center mt-2 mb-3">
                                                    <OffsetPagination CurrentPage="@viewModel.CurrentMemberPage"
                                                                      OnPageChanged="@(async page => await viewModel.OnMemberPageChangedAsync(page))"
                                                                      PageSize="10"
                                                                      TotalItems="@viewModel.AvailableUsers.TotalCount"/>
                                                </div>
                                            }

                                            if (viewModel.HasAdditionalMembers)
                                            {
                                                <div class="mb-3">
                                                    <FieldLabel class="text-[var(--text)] font-medium mb-2">Team members
                                                        (@viewModel.MemberBadgeCount)
                                                    </FieldLabel>
                                                    <div class="flex flex-wrap gap-2">
                                                        @foreach (var memberId in viewModel.SelectedMemberIds.Where(s => s != viewModel.UserId))
                                                        {
                                                            var member = viewModel.AvailableUsers.Data?.FirstOrDefault(u => u.Id == memberId);
                                                            var currentMember = viewModel.CurrentTeamMembers.FirstOrDefault(m => m.Id == memberId);
                                                            var displayName = member?.DisplayName ?? currentMember?.DisplayName ?? "Unknown";
                                                            var photoUrl = member?.AvatarUrl ?? currentMember?.AvatarUrl ?? "/images/user-avatar.svg";

                                                            <div
                                                                class="flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--main)] text-[var(--text-contrast)]">
                                                                <img src="@photoUrl"
                                                                     alt="@displayName"
                                                                     class="rounded-full w-6 h-6 object-cover"/>
                                                                <span class="text-sm">@displayName</span>
                                                                <button
                                                                    @onclick="@(() => viewModel.RemoveMember(memberId))"
                                                                    @onclick:stopPropagation="true"
                                                                    class="ml-1 hover:opacity-80 transition"
                                                                    title="Remove member">
                                                                    <svg class="w-4 h-4" fill="currentColor"
                                                                         viewBox="0 0 20 20">
                                                                        <path fill-rule="evenodd"
                                                                              d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                                                              clip-rule="evenodd"/>
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-sm text-[var(--text)]">No additional members selected
                                                    yet.</p>
                                            }
                                        }
                                        else
                                        {
                                            <div
                                                class="rounded-xl border border-dashed border-[var(--main)]/40 bg-[var(--section)]/60 p-4 text-sm text-[var(--text)]">
                                                No other members to manage right now.
                                            </div>
                                        }
                                    </FieldBody>
                                </Field>
                            </section>

                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-4">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text)]">Step 4</p>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mt-1">Manage invites</h3>
                                        <p class="text-sm text-[var(--text)]">Review pending invites and send new
                                            ones.</p>
                                    </div>
                                </div>
                            </section>

                            @if (viewModel.PendingInvites?.Count > 0)
                            {
                                <section
                                    class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-4">
                                    <div class="flex items-center justify-between">
                                        <h4 class="text-lg font-semibold text-[var(--text)]">Pending invites
                                            (@(viewModel.PendingInvites?.Count ?? 0))</h4>
                                    </div>
                                    @if (viewModel.IsLoadingInvites)
                                    {
                                        <Loading></Loading>
                                    }
                                    else if (viewModel.PendingInvites is { Count: > 0 })
                                    {
                                        <div
                                            class="space-y-2 max-h-60 overflow-y-auto border-2 border-[var(--main)] rounded-xl p-3 thin-scroll"
                                            style="background-color: var(--background);">
                                            @foreach (var invite in viewModel.PendingInvites)
                                            {
                                                var photoUrl = invite.Receiver?.AvatarUrl ?? "/images/user-avatar.png";
                                                <div
                                                    class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-[var(--main)]/10 transition-all"
                                                    style="color: var(--text);">
                                                    <div class="flex items-center gap-3">
                                                        <img src="@photoUrl"
                                                             alt="@invite.Receiver?.DisplayName"
                                                             class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]"/>
                                                        <div>
                                                            <span
                                                                class="font-medium">@invite.Receiver?.DisplayName</span>
                                                            <div class="text-xs opacity-70">
                                                                Invited @invite.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                                        </div>
                                                    </div>
                                                    <button @onclick="@(() => CancelInvite(invite.Id))"
                                                            class="px-3 py-1 bg-[var(--error)] hover:opacity-80 text-white rounded-lg text-sm font-medium transition">
                                                        Cancel
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div
                                            class="py-4 text-center opacity-60 border-2 border-[var(--main)] rounded-lg"
                                            style="color: var(--text); background-color: var(--background);">
                                            No pending invites
                                        </div>
                                    }
                                </section>
                            }

                            <section
                                class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6 space-y-4">
                                <div class="flex items-center justify-between">
                                    <h4 class="text-lg font-semibold text-[var(--text)]">Invite new members</h4>
                                </div>
                                <div class="mb-3">
                                    <TextEdit @bind-Text="viewModel.InviteSearch"
                                              @bind-Text:after="StateHasChanged"
                                              Placeholder="Search for users to invite"
                                              Role="TextRole.Search"
                                              KeyDown="@(async e => await viewModel.OnInviteSearchKeyDownAsync(e))"
                                              Class="w-full"
                                              Style="background-color: var(--background); color: var(--text); border-color: var(--main); border-radius: 0.65rem; padding: 0.85rem;"/>
                                </div>

                                @if (viewModel.IsLoadingInviteUsers)
                                {
                                    <Loading></Loading>
                                }
                                else
                                {
                                    <div
                                        class="max-h-60 overflow-y-auto mb-3 border-2 border-[var(--main)] rounded-xl p-2 thin-scroll"
                                        style="background-color: var(--background);">
                                        @if (viewModel.AvailableInviteUsers.Data.Count == 0)
                                        {
                                            <div class="py-3 text-center opacity-60" style="color: var(--text);">No
                                                users found
                                            </div>
                                        }
                                        else
                                        {
                                            foreach (var user in viewModel.AvailableInviteUsers.Data)
                                            {
                                                var isAlreadyMember = viewModel.SelectedMemberIds.Contains(user.Id);
                                                var isAlreadyInvited = viewModel.PendingInvites?.Any(i => i.ReceiverId == user.Id) ?? false;

                                                <div
                                                    class="flex items-center justify-between gap-3 py-2 px-3 rounded-lg transition-all hover:opacity-80 @(isAlreadyMember || isAlreadyInvited ? "opacity-50" : "")"
                                                    style="color: var(--text);">
                                                    <div class="flex items-center gap-3 flex-1">
                                                        <img src="@user.AvatarUrl"
                                                             alt="@user.DisplayName"
                                                             class="rounded-full w-10 h-10 object-cover flex-shrink-0 border border-[var(--main)]"/>
                                                        <span class="fw-500 truncate">@user.DisplayName</span>
                                                    </div>
                                                    @if (isAlreadyMember)
                                                    {
                                                        <span
                                                            class="text-xs px-2 py-1 bg-[var(--main)] rounded-full text-[var(--text-contrast)]">Member</span>
                                                    }
                                                    else if (isAlreadyInvited)
                                                    {
                                                        <span
                                                            class="text-xs px-2 py-1 bg-yellow-500 text-white rounded-full">Invited</span>
                                                    }
                                                    else
                                                    {
                                                        <button @onclick="@(() => SendInviteToUser(user.Id))"
                                                                class="px-3 py-1 bg-[var(--main)] hover:opacity-80 text-[var(--text-contrast)] rounded-lg text-sm font-medium transition">
                                                            Invite
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>

                                    @if (viewModel.AvailableInviteUsers is { Data: not null, TotalCount: > 0 })
                                    {
                                        <div class="flex justify-center mt-2">
                                            <OffsetPagination CurrentPage="@viewModel.CurrentInvitePage"
                                                              OnPageChanged="@(async page => await viewModel.OnInvitePageChangedAsync(page))"
                                                              PageSize="10"
                                                              TotalItems="@viewModel.AvailableInviteUsers.TotalCount"/>
                                        </div>
                                    }
                                }
                            </section>

                            <section class="rounded-2xl border border-[var(--main)] bg-[var(--section-secondary)] p-6">
                                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                                    <div>
                                        <h3 class="text-xl font-semibold text-[var(--text)]">Ready to update?</h3>
                                        <p class="text-sm text-[var(--text)]">Changes apply immediately and new invites
                                            are sent right away.</p>
                                    </div>
                                    <Button Color="Color.Primary"
                                            Clicked="@SubmitTeam"
                                            Loading="@viewModel.IsSubmitting"
                                            Class="w-full md:w-auto"
                                            Style="background-color: var(--main); color: var(--text-contrast); padding: 0.9rem 2.4rem; border-radius: 0.75rem; font-weight: 600; transition: all 0.2s;">
                                        Save changes
                                    </Button>
                                </div>
                            </section>
                        </div>
                    </Validations>
                </div>
            </div>
        </div>
    </div>
}

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>

@code {
    private Validations _validations = null!;
    private EditTeamViewModel? _viewModel;
    private PropertyChangedEventHandler? _propertyChangedHandler;
    private string? _userId;

    [Parameter] public string? Id { get; set; }

    private void ValidateProperty(ValidatorEventArgs e, string propertyPath)
    {
        if (_viewModel is null)
        {
            e.Status = ValidationStatus.Error;
            e.ErrorText = "Model not ready yet.";
            return;
        }

        var status = _viewModel.ValidateProperty(propertyPath);
        e.Status = status;
        if (status == ValidationStatus.Error)
        {
            e.ErrorText = _viewModel.GetValidationError(propertyPath);
        }
    }

    void ValidateName(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateTeamDto.Name));
    void ValidateDescription(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateTeamDto.Description));
    void ValidatePrivacy(ValidatorEventArgs e) => ValidateProperty(e, nameof(UpdateTeamDto.Privacy));

    private async Task SubmitTeam()
    {
        if (_viewModel is null)
        {
            return;
        }

        var success = await _viewModel.SubmitTeamAsync(_validations);
        if (success && Id is not null)
        {
            NavigationManager.NavigateTo($"/teams/{Id}");
        }
    }

    private async Task RemoveImage()
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.RemoveImageAsync();
    }

    private async Task HandleImageChanged(InputFileChangeEventArgs e)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnImageSelectedAsync(e);
    }

    private async Task SendInviteToUser(string receiverId)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.SendInviteToUserAsync(receiverId);
    }

    private async Task CancelInvite(string inviteId)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.RemoveInviteAsync(inviteId);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (_userId == null)
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        _viewModel = new EditTeamViewModel(TeamService, UsersService, TeamInvitesService, UpdateTeamDtoValidator, ToastService);
        _propertyChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        _viewModel.PropertyChanged += _propertyChangedHandler;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_viewModel is null || _userId is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(Id))
        {
            NavigationManager.NavigateTo("/404", forceLoad: true);
            return;
        }

        if (_viewModel.TeamId == Id && _viewModel.Model is not null && !_viewModel.IsLoading)
        {
            return;
        }

        var result = await _viewModel.InitializeAsync(Id, _userId);
        switch (result.Status)
        {
            case EditTeamLoadStatus.Success:
                break;
            case EditTeamLoadStatus.Unauthorized:
                await ToastService.Error(result.ErrorMessage ?? "You don't have permission to edit this team.");
                NavigationManager.NavigateTo($"/teams/{Id}");
                break;
            case EditTeamLoadStatus.NotFound:
            case EditTeamLoadStatus.Invalid:
                NavigationManager.NavigateTo("/404", forceLoad: true);
                break;
        }
    }

}
