@page "/teams/{teamId}"
@inject ITeamService TeamService
@inject ITeamsInvitesService TeamInvitesService
@using System.Security.Claims
@using MatchBy.DTOs.Team
@using MatchBy.DTOs.TeamInvite
@using MatchBy.Services.Teams
@using MatchBy.Services.TeamInvites
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@using Blazorise
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

@if (_isLoading)
{
    <div class="min-h-screen flex items-center justify-center">
        <Loading></Loading>
    </div>
}
else if (_hasError)
{
    <div class="min-h-screen bg-[var(--background)] px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div
                class="bg-[var(--section-secondary)] rounded-2xl border border-[var(--main)] shadow-sm p-8 text-center">
                <div class="mb-4">
                    <svg class="mx-auto w-16 h-16 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
                <h2 class="text-2xl font-bold text-[var(--text)] mb-2">Unable to Load Team</h2>
                <p class="text-[var(--text)] mb-2 opacity-75">@_errorMessage</p>
                <div class="flex gap-3 justify-center mt-6">
                    <button @onclick="RetryLoadTeam"
                            disabled="@_isRetrying"
                            class="px-6 py-2 bg-[var(--main)] hover:bg-[var(--main-hover)] text-[var(--text-contrast)] font-medium rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (_isRetrying)
                        {
                            <span>Retrying...</span>
                        }
                        else
                        {
                            <span>Try Again</span>
                        }
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/teams"))"
                            class="px-6 py-2 bg-[var(--section-secondary)] border border-[var(--text)]/20 text-[var(--text)] hover:bg-[var(--background)] font-medium rounded-lg transition">
                        Back to Teams
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else if (_team == null)
{
    <div class="min-h-screen flex items-center justify-center">
        <div class="text-center">
            <p class="text-[var(--text)] mb-4">Team not found.</p>
            <button @onclick="@(() => NavigationManager.NavigateTo("/teams"))"
                    class="px-6 py-2 bg-[var(--main)] hover:bg-[var(--main-hover)] text-[var(--text-contrast)] font-medium rounded-lg transition">
                Back to Teams
            </button>
        </div>
    </div>
}
else
{
    <div class="min-h-screen bg-[var(--background)] px-4 py-8">
        <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Main Content (Left) -->
            <div class="lg:col-span-2 space-y-6">
                <button @onclick="@(() => NavigationManager.NavigateTo("/teams"))"
                        class="flex items-center gap-2 text-[var(--text)] hover:text-[var(--main)] mb-6">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Back to Teams
                </button>
                <!-- Team Header Card -->
                <div class="bg-[var(--section-secondary)] rounded-2xl border border-[var(--main)] shadow-sm p-8">
                    <div class="flex items-start gap-6">
                        <div
                            class="w-24 h-24 rounded-full bg-gray-300 flex-shrink-0 overflow-hidden border-4 border-[var(--section-secondary)]">
                            @if (_team.ImageUrl is not null)
                            {
                                <img class="w-full h-full rounded-full flex-none object-cover"
                                     src="@(_team.ImageUrl ?? "/images/user-avatar.png")"
                                     alt="@_team.Name image"/>
                            }
                            else
                            {
                                <div class="w-full h-full rounded-full bg-[var(--section)]"></div>
                            }

                        </div>

                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h1 class="text-4xl font-bold text-[var(--main)]">@_team.Name</h1>
                                </div>
                                @if (_team.OwnerId == _userId)
                                {
                                    <button @onclick="@(() => NavigationManager.NavigateTo($"/teams/edit/{_team.Id}"))"
                                            class="px-6 py-2 bg-[var(--section-secondary)] border border-[var(--text)]/20 rounded-lg text-[var(--text)] hover:bg-[var(--background)] font-medium">
                                        Edit Team
                                    </button>
                                }
                            </div>

                            <p class="text-[var(--text)] mt-4 text-lg">@_team.Description</p>

                            <div class="flex flex-wrap gap-4 mt-6">
                                @*<div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-[var(--text)]" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11z"/>
                                    </svg>
                                    <span class="text-[var(--text)]">Porto, Portugal</span>
                                </div>*@
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-[var(--text)]" fill="currentColor" viewBox="0 0 24 24">
                                        <path
                                            d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-2.08-2.54-1.41 1.41L10.5 18l4.04-5.29z"/>
                                    </svg>
                                    <span
                                        class="text-[var(--text)]">Created on @_team.CreatedAtUtc.ToLocalTime().ToString("dd 'of' MMMM 'of' yyyy")</span>
                                </div>
                            </div>

                            @*<div class="flex gap-3 mt-6">
                                <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium">Recreativo</span>
                                <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium">Iniciantes</span>
                            </div>*@
                        </div>
                    </div>
                </div>

                <!-- Members Section -->
                <div class="bg-[var(--section-secondary)] rounded-2xl border border-[var(--main)] shadow-sm p-8">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-bold text-[var(--text)]">
                            Members (@(_team.Members.Count)/@(_team.MaxMembers))
                        </h2>
                        <p class="text-[var(--text)]">All active members of this team</p>
                    </div>

                    <div class="space-y-3 max-h-96 overflow-y-auto">
                        @if (_team?.Members != null && _team.Members.Any())
                        {
                            @foreach (var member in _team.Members)
                            {
                                <div
                                    class="flex items-center justify-between p-4 rounded-lg border border-[var(--main)] hover:bg-[var(--main)]/5 transition">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-12 h-12 rounded-full bg-gray-300 overflow-hidden border border-[var(--main)]">
                                            @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                            {
                                                <img src="@member.AvatarUrl" class="w-full h-full object-cover" alt=""/>
                                            }
                                            else
                                            {
                                                <img src="images/user-avatar.png" class="w-full h-full object-cover"
                                                     alt=""/>
                                            }
                                        </div>
                                        <div>
                                            <p class="font-medium text-[var(--text)]">@member.DisplayName</p>
                                            @if (member.Id == _team.OwnerId)
                                            {
                                                <span class="text-xs text-[var(--text)] opacity-70">You</span>
                                            }
                                        </div>
                                    </div>
                                    @if (member.Id == _team.OwnerId)
                                    {
                                        <span
                                            class="px-3 py-1 bg-[var(--main)] text-[var(--text-contrast)] rounded-full text-sm font-medium">Owner</span>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-[var(--text)] text-center py-8">No members yet.</p>
                        }
                    </div>
                </div>

                <!-- Invited Users Section (Only visible to team owner) -->
                @if (_team?.OwnerId == _userId)
                {
                    <div class="bg-[var(--section-secondary)] rounded-2xl border border-[var(--main)] shadow-sm p-8">
                        <div class="flex items-center justify-between mb-6">
                            <h2 class="text-2xl font-bold text-[var(--text)]">
                                Invited Users
                                @if (_pendingInvites != null)
                                {
                                    <span>(@_pendingInvites.Count)</span>
                                }
                            </h2>
                            <p class="text-[var(--text)] text-sm opacity-70">Pending invitations</p>
                        </div>

                        @if (_isLoadingInvites)
                        {
                            <div class="flex justify-center py-8">
                                <Loading></Loading>
                            </div>
                        }
                        else if (_pendingInvites is { Count: > 0 })
                        {
                            <div class="space-y-3 max-h-96 overflow-y-auto">
                                @foreach (var invite in _pendingInvites)
                                {
                                    <div
                                        class="flex items-center justify-between p-4 rounded-lg border border-[var(--main)] hover:bg-[var(--main)]/5 transition">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="w-12 h-12 rounded-full bg-gray-300 overflow-hidden border border-[var(--main)]">
                                                @if (!string.IsNullOrEmpty(invite.Receiver?.AvatarUrl))
                                                {
                                                    <img src="@invite.Receiver.AvatarUrl"
                                                         class="w-full h-full object-cover" alt=""/>
                                                }
                                                else
                                                {
                                                    <img src="images/user-avatar.png" class="w-full h-full object-cover"
                                                         alt=""/>
                                                }
                                            </div>
                                            <div>
                                                <p class="font-medium text-[var(--text)]">@invite.Receiver?.DisplayName</p>
                                                <span
                                                    class="text-xs text-[var(--text)] opacity-70">Invited @invite.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                            </div>
                                        </div>
                                        <span
                                            class="px-3 py-1 bg-yellow-500/20 text-yellow-600 rounded-full text-sm font-medium">Pending</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-[var(--text)] text-center py-8 opacity-70">No pending invitations.</p>
                        }
                    </div>
                }
            </div>

            <!-- Sidebar (Right) -->
            <div class="lg:col-span-1 lg:mt-12">
                <!-- Actions -->
                <div class="bg-[var(--section-secondary)] rounded-2xl border border-[var(--main)] shadow p-6 mb-6">
                    <h3 class="text-lg font-semibold text-[var(--text)] mb-5">Actions</h3>

                    @if (_team?.Members != null && _userId != null)
                    {
                        @if (_team.Members.All(m => m.Id != _userId) && _team.OwnerId != _userId)
                        {
                            <Button
                                    Clicked="@(() => JoinTeam(_team.Id))"
                                    Loading="@_isJoiningTeam"
                                    Disabled="@(_isJoiningTeam || _isLeavingTeam)"
                                    class="!block w-full py-3 mb-3 rounded-lg bg-[var(--main)] hover:opacity-90 text-[var(--text-contrast)] font-medium !text-center transition">
                                <span class="text-center">Join Team</span>
                            </Button>
                        }
                        else if (_team.Members.Any(m => m.Id == _userId) && _team.OwnerId != _userId)
                        {
                            <a href="/chat/@_team.ConversationId"
                               class="block w-full py-3 mb-3 rounded-lg bg-[var(--main)] hover:opacity-90 text-[var(--text-contrast)] font-medium text-center transition">
                                Go To Conversation
                            </a>

                            <Button Color="Color.Danger"
                                    Clicked="@(() => LeaveTeam(_team.Id))"
                                    Loading="@_isLeavingTeam"
                                    Disabled="@(_isJoiningTeam || _isLeavingTeam)"
                                    class="!block w-full py-3 mb-3 rounded-lg hover:opacity-90 text-[var(--text)] font-medium !text-center transition">
                                <span class="text-center">Leave Team</span>
                            </Button>
                        }
                        else
                        {
                            <a href="/chat/@_team.ConversationId"
                               class="block w-full py-3 mb-3 rounded-lg bg-[var(--main)] hover:opacity-90 text-[var(--text-contrast)] font-medium text-center transition">
                                Go To Conversation
                            </a>

                            <Button Color="Color.Danger"
                                    Clicked="@(() => LeaveTeam(_team.Id))"
                                    Loading="@_isLeavingTeam"
                                    Disabled="@(_isJoiningTeam || _isLeavingTeam)"
                                    class="!block w-full py-3 mb-3 rounded-lg hover:opacity-90 text-[var(--text)] font-medium !text-center transition">
                                <span class="text-center">Delete Team</span>
                            </Button>
                        }
                    }
                </div>


                <!-- Statistics -->
                <div class="bg-[var(--section-secondary)] rounded-2xl border  border-[var(--main)] shadow-sm p-6">
                    <h3 class="text-lg font-bold text-[var(--text)] mb-6">Statistics</h3>

                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-[var(--text)]">Total Members</span>
                            <span class="text-2xl font-bold text-[var(--text)]">@(_team?.Members.Count ?? 0)</span>
                        </div>

                        <div class="border-t border-[var(--main)] pt-4 flex items-center justify-between">
                            <span class="text-[var(--text)]">Available Spots</span>
                            <span class="text-2xl font-bold text-[var(--text)]">
                                @if (_team != null)
                                {
                                    @(_team.MaxMembers - _team.Members.Count)
                                }
                            </span>
                        </div>

                        <div class="border-t  border-[var(--main)] pt-4 flex items-center justify-between">
                            <span class="text-[var(--text)]">Occupancy Rate</span>
                            <span class="text-2xl font-bold text-[var(--text)]">
                                @if (_team != null)
                                {
                                    var percentage = _team.Members.Count / (double)_team.MaxMembers * 100;
                                    @($"{percentage:F2}%")
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>

@code {
    [Parameter] public string TeamId { get; set; } = string.Empty;
    private TeamDto? _team;
    private List<TeamInviteDto>? _pendingInvites;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;
    private string? _userId;

    // Loading and error states
    private bool _isLoading = true;
    private bool _hasError;
    private string _errorMessage = string.Empty;
    private bool _isRetrying;
    private bool _isLoadingInvites;
    private bool _isJoiningTeam;
    private bool _isLeavingTeam;

    protected override async Task OnInitializedAsync() => await LoadTeamDataAsync();

    private async Task LoadTeamDataAsync()
    {
        if (string.IsNullOrWhiteSpace(TeamId))
        {
            SetErrorState("Invalid team ID provided.");
            return;
        }

        _isLoading = true;
        _hasError = false;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(_userId))
            {
                SetErrorState("You must be logged in to view team details.");
                return;
            }

            var result = await TeamService.GetTeamByIdAsync(TeamId, _userId, CancellationToken.None);

            if (!result.Success)
            {
                var errorMsg = result.ErrorMessages.Any()
                    ? string.Join(", ", result.ErrorMessages)
                    : "Failed to load team details.";

                // If team not found or access denied, navigate away with a message
                if (result.ErrorMessages.Any(m => m.Contains("not found", StringComparison.OrdinalIgnoreCase) ||
                                                  m.Contains("access denied", StringComparison.OrdinalIgnoreCase)))
                {
                    SetErrorState(result.ErrorMessages[0]);
                    return;
                }

                SetErrorState(errorMsg);
                return;
            }

            if (result.Data == null)
            {
                SetErrorState("Team data is null.");
                return;
            }

            _team = result.Data;
            _isLoading = false;
            _hasError = false;
            StateHasChanged();

            // Load pending invites if user is the owner
            if (_team.OwnerId == _userId)
            {
                await LoadPendingInvites();
            }
        }
        catch (Exception ex)
        {
            SetErrorState($"An unexpected error occurred: {ex.Message}");
        }
    }

    private async Task RetryLoadTeam()
    {
        if (_isRetrying) return;

        _isRetrying = true;
        StateHasChanged();

        await LoadTeamDataAsync();

        _isRetrying = false;
        StateHasChanged();
    }

    private async Task LoadPendingInvites()
    {
        if (string.IsNullOrWhiteSpace(TeamId) || _isLoadingInvites)
            return;

        _isLoadingInvites = true;
        StateHasChanged();

        try
        {
            var result = await TeamInvitesService.GetInvitesForTeam(TeamId, 1, 100, CancellationToken.None);

            if (result is { Success: true, Data: not null })
            {
                _pendingInvites = result.Data.Data
                    .Where(i => i.Status == InviteStatus.Pending && !i.IsExpired)
                    .ToList();
            }
            else
            {
                _pendingInvites = [];
                // Only show error if it's not a simple "no invites" case
                if (result.ErrorMessages.Any(m => !m.Contains("not found", StringComparison.OrdinalIgnoreCase)))
                {
                    var errorMsg = result.ErrorMessages.Any()
                        ? string.Join(", ", result.ErrorMessages)
                        : "Failed to load pending invitations.";
                    await ToastService.Error(errorMsg);
                }
            }
        }
        catch (Exception ex)
        {
            _pendingInvites = [];
            await ToastService.Error($"Error loading invitations: {ex.Message}");
        }
        finally
        {
            _isLoadingInvites = false;
            StateHasChanged();
        }
    }

    private async Task LeaveTeam(string teamId)
    {
        if (string.IsNullOrWhiteSpace(_userId) || _isLeavingTeam || _isJoiningTeam)
            return;

        if (string.IsNullOrWhiteSpace(teamId))
        {
            await ToastService.Error("Invalid team ID.");
            return;
        }

        _isLeavingTeam = true;
        StateHasChanged();

        try
        {
            var result = await TeamService.LeaveTeamAsync(teamId, _userId, CancellationToken.None);

            if (!result.Success)
            {
                var errorMsg = result.ErrorMessages.Any()
                    ? string.Join(", ", result.ErrorMessages)
                    : "Error leaving team.";
                await ToastService.Error(errorMsg);
                return;
            }

            // result.Data == 1 means team was deleted (owner left)
            // result.Data == 2 means user left but team still exists
            if (result.Data == 1)
            {
                // Wait for user to see the toast before navigating
                NavigationManager.NavigateTo("/teams");
                await Task.Delay(100);
                await ToastService.Success("Team deleted successfully!", "Leave Team");
            }
            else
            {
                // For private teams, navigate away after leaving
                if (_team?.Privacy == TeamPrivacy.Private)
                {
                    NavigationManager.NavigateTo("/teams");
                    // Wait for user to see the toast before navigating
                    await Task.Delay(100);
                    await ToastService.Success("Successfully left the team!", "Leave Team");
                    return;
                }

                await ToastService.Success("Successfully left the team!", "Leave Team");

                // Reload team data to reflect the change
                await ReloadTeamDataAsync();
            }
        }
        catch (Exception ex)
        {
            await ToastService.Error($"An error occurred while leaving the team: {ex.Message}");
        }
        finally
        {
            _isLeavingTeam = false;
            StateHasChanged();
        }
    }

    private async Task JoinTeam(string teamId)
    {
        if (string.IsNullOrWhiteSpace(_userId) || _isJoiningTeam || _isLeavingTeam)
            return;

        if (string.IsNullOrWhiteSpace(teamId))
        {
            await ToastService.Error("Invalid team ID.");
            return;
        }

        _isJoiningTeam = true;
        StateHasChanged();

        try
        {
            var result = await TeamService.JoinTeamAsync(teamId, _userId, CancellationToken.None);

            if (!result.Success)
            {
                var errorMsg = result.ErrorMessages.Any()
                    ? string.Join(", ", result.ErrorMessages)
                    : "Error joining team.";
                await ToastService.Error(errorMsg);
                return;
            }

            // If result.Data is false, this is an unexpected case - just navigate
            // (Based on service implementation, this should not happen if Success is true)
            if (!result.Data)
            {
                NavigationManager.NavigateTo("/teams");
                return;
            }

            await ToastService.Success("Successfully joined the team!", "Join Team");

            // Reload team data to reflect the change
            await ReloadTeamDataAsync();
        }
        catch (Exception ex)
        {
            await ToastService.Error($"An error occurred while joining the team: {ex.Message}");
        }
        finally
        {
            _isJoiningTeam = false;
            StateHasChanged();
        }
    }

    private async Task ReloadTeamDataAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(TeamId) || string.IsNullOrWhiteSpace(_userId))
                return;

            var result = await TeamService.GetTeamByIdAsync(TeamId, _userId, CancellationToken.None);

            if (result.Success && result.Data != null)
            {
                _team = result.Data;

                // Reload pending invites if user is the owner
                if (_team.OwnerId == _userId)
                {
                    await LoadPendingInvites();
                }
            }
            else
            {
                // If we can't reload, show error but don't break the UI
                var errorMsg = result.ErrorMessages.Any()
                    ? string.Join(", ", result.ErrorMessages)
                    : "Failed to refresh team data.";
                await ToastService.Error(errorMsg);
            }
        }
        catch (Exception ex)
        {
            await ToastService.Error($"Error refreshing team data: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void SetErrorState(string errorMessage)
    {
        _isLoading = false;
        _hasError = true;
        _errorMessage = errorMessage;
        _team = null;
        _pendingInvites = null;
    }

}