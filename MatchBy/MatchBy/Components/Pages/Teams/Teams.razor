@page "/teams"
@using System.ComponentModel
@using System.Security.Claims
@using MatchBy.DTOs.Team
@using MatchBy.Services.Teams
@using Blazorise
@rendermode @(new InteractiveServerRenderMode(false))
@attribute [StreamRendering]
@inject ITeamService TeamService
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable
@inject NavigationManager NavigationManager

@if (_viewModel is null)
{
    <div class="min-h-screen flex items-center justify-center bg-[var(--background)]">
        <Loading></Loading>
    </div>
}
else
{
    var viewModel = _viewModel!;
    <div class="min-h-screen p-8 bg-[var(--background)]">
        <div class="max-w-7xl mx-auto">
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                    <li class="inline-flex items-center">
                        <a href="/"
                           class="inline-flex items-center text-sm font-medium text-[var(--text)] hover:text-fg-brand">
                            <svg class="w-4 h-4 me-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24"
                                 height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="m4 12 8-8 8 8M6 10.5V19a1 1 0 0 0 1 1h3v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h3a1 1 0 0 0 1-1v-8.5"/>
                            </svg>
                            Home
                        </a>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center space-x-1.5">
                            <svg class="w-3.5 h-3.5 rtl:rotate-180 text-[var(--text)]" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="m9 5 7 7-7 7"/>
                            </svg>
                            <span class="inline-flex items-center text-sm font-medium text-[var(--text)]">Teams</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <!-- Header -->
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h1 class="text-4xl font-bold mb-2 text-[var(--text)]">Teams</h1>
                    <p class="text-[var(--text)] opacity-70">Manage your teams or find new ones to join</p>
                </div>
                <a href="/teams/create"
                   class="px-6 py-3 rounded-lg font-medium flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)]">
                    <span class="text-xl">+</span>
                    Create Team
                </a>
            </div>

            <!-- Toggle Tabs -->
            <div class="flex gap-4 mb-8">
                <button
                    class="@(viewModel.ActiveTab == "my" ? "bg-[var(--section-secondary)] border-2 border-[var(--main)]" : "bg-[var(--section)] border-2 border-transparent") px-8 py-3 rounded-lg font-medium text-[var(--text)] hover:bg-[var(--section-secondary)] transition-all"
                    @onclick='() => UpdateUrl("my")'>
                    My Teams
                </button>
                <button
                    class="@(viewModel.ActiveTab == "search" ? "bg-[var(--section-secondary)] border-2 border-[var(--main)]" : "bg-[var(--section)] border-2 border-transparent") px-8 py-3 rounded-lg font-medium text-[var(--text)] hover:bg-[var(--section-secondary)] transition-all"
                    @onclick='() => UpdateUrl("search")'>
                    Search Teams
                </button>
            </div>

            @if (viewModel.ActiveTab == "my")
            {
                <!-- My Teams View -->
                <div>
                    <!-- Teams I Own -->
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 text-[var(--text)]">Teams I Own</h2>
                        @if (viewModel.TeamsYouOwn is not null && viewModel.TeamsYouOwn.Count == 0)
                        {
                            <div
                                class="rounded-xl border border-[var(--main)] p-16 text-center bg-[var(--section-secondary)]">
                                <p class="mb-6 text-[var(--text)] opacity-70">You haven't created any team yet</p>
                                <a href="/teams/create"
                                   class="px-6 py-3 rounded-lg font-medium inline-flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)]">
                                    <span class="text-xl">+</span>
                                    Create First Team
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                @if (viewModel.TeamsYouOwn is null)
                                {
                                    <Loading
                                        Class="col-span-full min-h-[200px] flex items-center justify-center"></Loading>
                                }
                                else
                                {
                                    foreach (var team in viewModel.TeamsYouOwn)
                                    {
                                        <TeamCard Team="@team" UserId="@viewModel.UserId"></TeamCard>
                                    }
                                }
                            </div>
                            if (viewModel.TeamsYouOwnPagination != null && viewModel.TeamsYouOwn?.Count > 0)
                            {
                                <div class="flex justify-center mt-8">
                                    <OffsetPagination CurrentPage="@viewModel.CurrentPageOwnTeams"
                                                      OnPageChanged="@OnPageChangedOwnTeams"
                                                      PageSize="@(viewModel.TeamsYouOwnPagination?.PageSize ?? 6)"
                                                      TotalItems="@(viewModel.TeamsYouOwnPagination?.TotalCount ?? 0)"></OffsetPagination>
                                </div>
                            }
                        }
                    </div>

                    <!-- Teams I Participate -->
                    <div>
                        <h2 class="text-2xl font-bold mb-6 text-[var(--text)]">Teams I Participate</h2>
                        @if (viewModel.TeamsYouParticipate is not null && viewModel.TeamsYouParticipate.Count == 0)
                        {
                            <div
                                class="rounded-xl border border-[var(--main)] p-16 text-center bg-[var(--section-secondary)]">
                                <p class="mb-6 text-[var(--text)] opacity-70">You haven't joined any team yet</p>
                                <a href="/teams/create"
                                   class="px-6 py-3 rounded-lg font-medium inline-flex items-center gap-2 transition-colors bg-[var(--main)] text-[var(--text-contrast)] hover:bg-[var(--main-hover)]">
                                    <span class="text-xl">+</span>
                                    Join a Team
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                @if (viewModel.TeamsYouParticipate is null)
                                {
                                    <Loading
                                        Class="col-span-full min-h-[200px] flex items-center justify-center"></Loading>
                                }
                                else
                                {
                                    foreach (var team in viewModel.TeamsYouParticipate)
                                    {
                                        <TeamCard Team="@team" UserId="@viewModel.UserId"></TeamCard>
                                    }
                                }
                            </div>
                            if (viewModel.TeamsYouParticipatePagination != null && viewModel.TeamsYouParticipate?.Count > 0)
                            {
                                <div class="flex justify-center mt-8">
                                    <OffsetPagination CurrentPage="@viewModel.CurrentPageParticipatingTeams"
                                                      OnPageChanged="@OnPageChangedParticipatingTeams"
                                                      PageSize="@(viewModel.TeamsYouParticipatePagination?.PageSize ?? 6)"
                                                      TotalItems="@(viewModel.TeamsYouParticipatePagination?.TotalCount ?? 0)"></OffsetPagination>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Search Teams View -->
                <div>
                    <!-- Search Filters -->
                    <div class="rounded-xl border border-[var(--main)] p-6 mb-8 bg-[var(--section-secondary)]">
                        <h3 class="text-xl font-bold mb-2 text-[var(--text)]">Search Filters</h3>
                        <p class="mb-6 text-[var(--text)] opacity-70">Find the perfect team for you</p>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Search Input -->
                            <div>
                                <label class="block text-sm font-medium mb-2 text-[var(--text)]">Search</label>
                                <div class="relative">
                                    <input @bind:get="viewModel.TeamQueryParameters.Query"
                                           @bind:set="@(text => viewModel.UpdateTeamQueryParameters(p => p with { Query = text }))"
                                           type="text"
                                           placeholder="Name, description or tags..."
                                           class="w-full px-4 py-3 rounded-lg border border-[var(--main)] bg-[var(--background)] text-[var(--text)] focus:outline-none focus:ring-2 focus:ring-[var(--main)]"/>
                                </div>
                            </div>

                            <!-- Sport Dropdown -->
                            <div>
                                <label class="block text-sm font-medium mb-2 text-[var(--text)]">Privacy</label>
                                <Select TValue="Privacy"
                                        SelectedValue="@viewModel.TeamQueryParameters.Privacy"
                                        SelectedValueChanged="@(v => viewModel.UpdateTeamQueryParameters(p => p with { Privacy = v }))"
                                        class="w-full px-4 py-3 rounded-lg border !border-[var(--main)] !bg-[var(--background)] text-[var(--text)] !focus:outline-none !focus:ring-2 !focus:ring-[var(--main)]">>
                                    @foreach (var item in Enum.GetValues<Privacy>())
                                    {
                                        <SelectItem Value="@item">@item.ToString()</SelectItem>
                                    }
                                </Select>
                            </div>

                            <!-- Sort By Dropdown -->
                            <div>
                                <label class="block text-sm font-medium mb-2 text-[var(--text)]">Sort By</label>
                                <Select TValue="SortBy"
                                        SelectedValue="@viewModel.TeamQueryParameters.SortBy"
                                        SelectedValueChanged="@(v => viewModel.UpdateTeamQueryParameters(p => p with { SortBy = v }))"
                                        class="w-full px-4 py-3 rounded-lg border !border-[var(--main)] !bg-[var(--background)] text-[var(--text)] !focus:outline-none !focus:ring-2 !focus:ring-[var(--main)]">
                                    @foreach (var item in Enum.GetValues<SortBy>())
                                    {
                                        <SelectItem Value="@item">@item.ToString()</SelectItem>
                                    }
                                </Select>
                            </div>

                            <!-- Order Dropdown -->
                            <div>
                                <label class="block text-sm font-medium mb-2 text-[var(--text)]">Order</label>
                                <Select TValue="OrderBy"
                                        SelectedValue="@viewModel.TeamQueryParameters.OrderBy"
                                        SelectedValueChanged="@(v => viewModel.UpdateTeamQueryParameters(p => p with { OrderBy = v }))"
                                        class="w-full px-4 py-3 rounded-lg border border !border-[var(--main)] !bg-[var(--background)] text-[var(--text)] !focus:outline-none !focus:ring-2 !focus:ring-[var(--main)]">
                                    @foreach (var item in Enum.GetValues<OrderBy>())
                                    {
                                        <SelectItem Value="@item">@item.ToString()</SelectItem>
                                    }
                                </Select>
                            </div>
                        </div>
                        <Button Clicked="SearchTeams"
                                class="mt-6 shrink-0 rounded-lg !p-2.5 !sm:py-2 sm:px-4 text-sm transition-all font-medium active:scale-95 touch-manipulation flex items-center justify-center gap-2 hover:opacity-90"
                                Style="background-color: var(--main); color: var(--text-contrast);">
                            <span class="hidden sm:inline whitespace-nowrap">Search Teams</span>
                        </Button>
                    </div>

                    <div>
                        @if (viewModel.SearchedTeams?.Count > 0)
                        {
                            <h2 class="text-2xl font-bold mb-6 text-[var(--text)]">Results
                                (@(viewModel.SearchedTeams?.Count))</h2>
                        }
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @if (viewModel.SearchedTeams is null)
                            {
                                <Loading Class="col-span-full min-h-[200px] flex items-center justify-center"></Loading>
                            }
                            else if (viewModel.SearchedTeams.Count == 0)
                            {
                                <div class="col-span-full">
                                    <div
                                        class="flex flex-col items-center justify-center py-16 px-4 rounded-lg bg-[var(--section)]/50 border border-dashed border-[var(--main)]/20">
                                        <svg class="w-16 h-16 text-[var(--main)]/40 mb-4" aria-hidden="true"
                                             xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                                  stroke-width="1.5"
                                                  d="M18.5 4h-13m13 16h-13M9 9h6m-6 4h6m-11-9v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>
                                        </svg>
                                        <h3 class="text-xl font-semibold text-[var(--text)] mb-2">No teams found</h3>
                                        <p class="text-center text-[var(--text)]/70 mb-6 max-w-md">
                                            We couldn't find any teams matching your search. Try adjusting your filters
                                            or
                                            search criteria.
                                        </p>
                                        <NavLink href="/teams"
                                                 class="px-6 py-2 bg-[var(--main)] text-[var(--text-contrast)] rounded-lg hover:bg-[var(--main-hover)] transition-colors font-medium">
                                            Browse all teams
                                        </NavLink>
                                    </div>
                                </div>
                            }
                            else
                            {
                                foreach (var team in viewModel.SearchedTeams)
                                {
                                    <TeamCard Team="@team" UserId="@viewModel.UserId"></TeamCard>
                                }
                            }
                        </div>
                        @if (viewModel.SearchedTeamsPagination != null && viewModel.SearchedTeams?.Count > 0)
                        {
                            <div class="flex justify-center mt-8">
                                <OffsetPagination CurrentPage="@viewModel.CurrentPageSearchedTeams"
                                                  OnPageChanged="@OnPageChangedSearchedTeams"
                                                  PageSize="@(viewModel.SearchedTeamsPagination?.PageSize ?? 6)"
                                                  TotalItems="@(viewModel.SearchedTeamsPagination?.TotalCount ?? 0)"></OffsetPagination>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

<ToastProvider Placement="ToasterPlacement.TopEnd" Class="mt-12"/>

@code {
    private TeamsViewModel? _viewModel;
    private PropertyChangedEventHandler? _propertyChangedHandler;
    private bool _isAuthenticated;
    private string? _userId;
    
    [Parameter, SupplyParameterFromQuery] public string? Tab { get; set; }

    protected override void OnInitialized()
    {
        _viewModel = new TeamsViewModel(TeamService);
        _propertyChangedHandler = async (_, _) => await InvokeAsync(StateHasChanged);
        _viewModel.PropertyChanged += _propertyChangedHandler;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (_viewModel != null)
        {
            await _viewModel.InitializeAsync(_userId, _isAuthenticated);
        }
    }

    protected override void OnParametersSet()
    {
        if (_viewModel != null)
        {
            _viewModel.ActiveTab = Tab ?? "my";
        }
    }

    void UpdateUrl(string tab)
    {
        var uri = NavigationManager.GetUriWithQueryParameters(
            new Dictionary<string, object?>
            {
                ["tab"] = string.IsNullOrWhiteSpace(tab) ? null : tab
            });

        NavigationManager.NavigateTo(uri, replace: true);
    }


    private async Task SearchTeams()
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.SearchTeamsAsync();
    }

    private async Task OnPageChangedOwnTeams(int page)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnPageChangedAsync(page, TeamsPageType.OwnTeams);
    }

    private async Task OnPageChangedParticipatingTeams(int page)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnPageChangedAsync(page, TeamsPageType.ParticipatingTeams);
    }

    private async Task OnPageChangedSearchedTeams(int page)
    {
        if (_viewModel is null)
        {
            return;
        }

        await _viewModel.OnPageChangedAsync(page, TeamsPageType.SearchedTeams);
    }

    public void Dispose()
    {
        if (_viewModel != null && _propertyChangedHandler != null)
        {
            _viewModel.PropertyChanged -= _propertyChangedHandler;
        }
    }

}